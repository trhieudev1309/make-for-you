@model FUNews.Presentation.Pages.Staff.Categories.IndexModel

@{
    var category = Model.EditCategory;
    var categories = Model.AllCategories;
    var isUsed = Model.IsUsed;
}

<div class="modal fade" id="editCategoryModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Edit Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="editCategoryForm"
                  method="post"
                  asp-page-handler="Edit">

                <div class="modal-body">

                    <input type="hidden" asp-for="EditCategory.CategoryId" />

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label class="form-label">Category Name *</label>
                        <input asp-for="EditCategory.CategoryName"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description *</label>
                        <textarea asp-for="EditCategory.CategoryDesciption"
                                  class="form-control"
                                  rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Parent Category</label>
                        <select asp-for="EditCategory.ParentCategoryId"
                                class="form-select"
                                disabled="@isUsed">
                            <option value="">-- None --</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c.CategoryId">
                                    @c.CategoryName
                                </option>
                            }
                        </select>

                        @if (isUsed)
                        {
                            <input type="hidden" asp-for="EditCategory.ParentCategoryId" />
                            <small class="text-warning">
                                Parent category cannot be changed because this category is already used by articles.
                            </small>
                        }
                    </div>

                    <div class="form-check form-switch">
                        <input asp-for="EditCategory.IsActive"
                               class="form-check-input"
                               type="checkbox" />
                        <label class="form-check-label">
                            Active
                        </label>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">
                        Save
                    </button>
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />