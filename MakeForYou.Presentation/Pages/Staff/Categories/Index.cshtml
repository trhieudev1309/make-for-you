@page
@model FUNews.Presentation.Pages.Staff.Categories.IndexModel
@{
    ViewData["Title"] = "Manage Categories";
}

<div class="container mt-4 animate-fade">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-semibold mb-1">Manage Categories</h2>
            <p class="text-muted mb-0">
                Organize article categories and control their availability.
            </p>
        </div>

        <button class="btn btn-success" onclick="openCreateModal()">
            + Create Category
        </button>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger animate-fade">
            @TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm mb-4 animate-fade" style="animation-delay: 0.1s;">
        <div class="card-body">
            <form method="get" asp-page="./Index" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small text-muted">Keyword</label>
                    <input class="form-control"
                           asp-for="Keyword"
                           placeholder="Name or description" />
                </div>

                <div class="col-md-3">
                    <button class="btn btn-primary me-2">Search</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">
                        Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow animate-fade" style="animation-delay: 0.2s;">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Parent</th>
                        <th class="text-center">Articles</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Categories)
                    {
                        var articleCount = Model.ArticleCounts.ContainsKey(c.CategoryId)
                        ? Model.ArticleCounts[c.CategoryId]
                        : 0;

                        <tr>
                            <td class="fw-semibold">@c.CategoryName</td>
                            <td class="text-muted small">@c.CategoryDesciption</td>
                            <td>@(c.ParentCategory?.CategoryName ?? "—")</td>
                            <td class="text-center fw-semibold">@articleCount</td>
                            <td>
                                <span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">
                                    @(c.IsActive  ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-warning"
                                        onclick="openEditModal(@c.CategoryId)">
                                    Edit
                                </button>

                                <a asp-page="./Index"
                                   asp-page-handler="Toggle"
                                   asp-route-id="@c.CategoryId"
                                   class="btn btn-sm btn-outline-secondary">
                                    Toggle
                                </a>

                                <a asp-page="./Index"
                                   asp-page-handler="Delete"
                                   asp-route-id="@c.CategoryId"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Delete this category?');">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        function openCreateModal() {
            $.get('/Staff/Categories?handler=Create', function (html) {
                $('#modalContainer').html(html);
                $('#createCategoryModal').modal('show');
            });
        }

        $(document).on('submit', '#createCategoryForm', function (e) {
            e.preventDefault();

            $.ajax({
                url: '/Staff/Categories?handler=Create',
                type: 'POST',
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        $('#createCategoryBody').html(res);
                        $.validator.unobtrusive.parse('#createCategoryForm');
                    }
                }
            });
        });

        function openEditModal(id) {
            $.get(`/Staff/Categories?handler=Edit&id=${id}`, function (html) {
                $('#modalContainer').html(html);
                $('#editCategoryModal').modal('show');
            });
        }

        $(document).on('submit', '#editCategoryForm', function (e) {
            e.preventDefault();

            $.ajax({
                url: '/Staff/Categories?handler=Edit',
                type: 'POST',
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        $('#modalContainer').html(res);
                        $('#editCategoryModal').modal('show');
                        $.validator.unobtrusive.parse('#editCategoryForm');
                    }
                }
            });
        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}