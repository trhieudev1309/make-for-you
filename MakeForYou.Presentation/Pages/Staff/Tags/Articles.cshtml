@page "{id:int}"
@model FUNews.Presentation.Pages.Staff.Tags.ArticlesModel

@{
    ViewData["Title"] = "Articles by Tag";
}

<div class="container mt-4 animate-fade">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-semibold mb-0">
            Articles using tag:
            <span class="text-primary">@Model.TagName</span>
        </h2>

        <a asp-page="./Index"
           class="btn btn-outline-secondary">
            ← Back to Tags
        </a>
    </div>

    @if (!Model.Articles.Any())
    {
        <div class="alert alert-info">
            No articles are using this tag.
        </div>
    }
    else
    {
        <div class="card border-0 shadow">
            <div class="card-body p-0">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Created Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var article in Model.Articles)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    @article.NewsTitle
                                </td>

                                <td>
                                    @article.CreatedDate?.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    <span class="badge @(article.NewsStatus ? "bg-success" : "bg-secondary")">
                                        @(article.NewsStatus ? "Active" : "Inactive")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
    }

</div>