@page
@model FUNews.Presentation.Pages.Staff.Home.IndexModel
@{
    ViewData["Title"] = "Staff Dashboard";
}

<div class="container mt-4 animate-fade">

    <div class="mb-4">
        <h2 class="fw-semibold mb-1">Staff Dashboard</h2>
        <p class="text-muted mb-0">
            Manage your content efficiently from one central workspace.
        </p>
    </div>

    <div class="row g-4">

        <!-- News Articles -->
        <div class="col-md-4 animate-fade" style="animation-delay: 0.1s;">
            <div class="card border-0 shadow-sm h-100 dashboard-card">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary fs-3">
                        📰
                    </div>
                    <h5 class="fw-semibold">News Articles</h5>
                    <p class="text-muted small flex-grow-1">
                        Create, update, and manage your news articles.
                    </p>
                    <a asp-page="/Staff/NewsArticles/Index"
                       class="btn btn-outline-primary btn-sm mt-auto">
                        Manage
                    </a>
                </div>
            </div>
        </div>

        <!-- Categories -->
        <div class="col-md-4 animate-fade" style="animation-delay: 0.2s;">
            <div class="card border-0 shadow-sm h-100 dashboard-card">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-success fs-3">
                        📂
                    </div>
                    <h5 class="fw-semibold">Categories</h5>
                    <p class="text-muted small flex-grow-1">
                        Organize articles using structured categories.
                    </p>
                    <a asp-page="/Staff/Categories/Index"
                       class="btn btn-outline-success btn-sm mt-auto">
                        Manage
                    </a>
                </div>
            </div>
        </div>

        <!-- Tags -->
        <div class="col-md-4 animate-fade" style="animation-delay: 0.3s;">
            <div class="card border-0 shadow-sm h-100 dashboard-card">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-warning fs-3">
                        🏷️
                    </div>
                    <h5 class="fw-semibold">Tags</h5>
                    <p class="text-muted small flex-grow-1">
                        Create and maintain article tags.
                    </p>
                    <a asp-page="/Staff/Tags/Index"
                       class="btn btn-outline-warning btn-sm mt-auto">
                        Manage
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>