@model FUNews.Presentation.Pages.Staff.NewsArticles.IndexModel

<div asp-validation-summary="All" class="text-danger"></div>

<div class="mb-3">
    <label asp-for="CreateArticle.NewsTitle"></label>
    <input asp-for="CreateArticle.NewsTitle" class="form-control" />
    <span asp-validation-for="CreateArticle.NewsTitle" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CreateArticle.Headline"></label>
    <input asp-for="CreateArticle.Headline" class="form-control" />
    <span asp-validation-for="CreateArticle.Headline" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CreateArticle.CategoryId"></label>
    <select asp-for="CreateArticle.CategoryId" class="form-select">
        <option value="">-- Select category --</option>
        @foreach (var c in Model.Categories)
        {
            <option value="@c.CategoryId">
                @c.CategoryName
            </option>
        }
    </select>
    <span asp-validation-for="CreateArticle.CategoryId" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CreateArticle.NewsContent"></label>
    <textarea asp-for="CreateArticle.NewsContent"
              class="form-control"
              rows="5"></textarea>
    <span asp-validation-for="CreateArticle.NewsContent" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CreateArticle.NewsSource"></label>
    <input asp-for="CreateArticle.NewsSource" class="form-control" />
</div>

<div class="form-check form-switch mb-3">
    <input asp-for="CreateArticle.NewsStatus"
           class="form-check-input"
           type="checkbox" />
    <label asp-for="CreateArticle.NewsStatus"
           class="form-check-label">
        Active
    </label>
</div>

@if (Model.Tags != null)
{
    <div class="mb-3">
        <label class="form-label">Tags</label>
        <div class="row">
            @foreach (var tag in Model.Tags)
            {
                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="CreateTagIds"
                               value="@tag.TagId" />
                        <label class="form-check-label">
                            @tag.TagName
                        </label>
                    </div>
                </div>
            }
        </div>
    </div>
}

<input type="hidden" asp-for="CreateArticle.NewsArticleId" />