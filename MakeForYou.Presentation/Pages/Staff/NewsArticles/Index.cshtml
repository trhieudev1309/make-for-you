@page
@model FUNews.Presentation.Pages.Staff.NewsArticles.IndexModel

@{
    ViewData["Title"] = "My News Articles";
}

<div class="container mt-4 animate-fade">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-semibold mb-1">My News Articles</h2>
            <p class="text-muted mb-0">
                Manage, edit, and track your published content.
            </p>
        </div>

        <button class="btn btn-success"
                onclick="openCreateModal()">
            + Create Article
        </button>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4 animate-fade" style="animation-delay: 0.1s;">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="form-label small text-muted">Keyword</label>
                    <input asp-for="Keyword"
                           class="form-control"
                           placeholder="Title, author, category" />
                </div>

                <div class="col-md-3">
                    <button class="btn btn-primary me-2">Filter</button>
                    <a asp-page="./Index"
                       class="btn btn-outline-secondary">
                        Reset
                    </a>
                </div>

            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow animate-fade" style="animation-delay: 0.2s;">
        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Author</th>
                        <th>Created</th>
                        <th>Modified</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Articles)
                    {
                        <tr class="table-row-animate">
                            <td class="fw-semibold">@item.NewsTitle</td>

                            <td>@item.Category?.CategoryName</td>

                            <td>
                                <span class="badge @(item.NewsStatus == true ? "bg-success" : "bg-secondary")">
                                    @(item.NewsStatus == true ? "Active" : "Inactive")
                                </span>
                            </td>

                            <td>@item.CreatedBy?.AccountName</td>

                            <td>@item.CreatedDate?.ToString("dd/MM/yyyy")</td>

                            <td>@item.ModifiedDate?.ToString("dd/MM/yyyy")</td>

                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary"
                                        onclick="openEditModal('@item.NewsArticleId')">
                                    Edit
                                </button>

                                <a class="btn btn-sm btn-outline-danger"
                                   asp-page-handler="Delete"
                                   asp-route-id="@item.NewsArticleId"
                                   onclick="return confirm('Are you sure you want to delete this article?');">
                                    Delete
                                </a>

                                <a class="btn btn-sm btn-outline-info"
                                   asp-page-handler="Duplicate"
                                   asp-route-id="@item.NewsArticleId"
                                   onclick="return confirm('Duplicate this article?');">
                                    Duplicate
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>

        function openCreateModal() {
            $.get('?handler=Create', function (html) {
                $('#modalContainer').html(html);
                $('#createArticleModal').modal('show');
            });
        }

        $(document).on('submit', '#createArticleForm', function (e) {
            e.preventDefault();

            $.ajax({
                url: '?handler=Create',
                type: 'POST',
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        $('#createArticleBody').html(res);
                        $.validator.unobtrusive.parse('#createArticleForm');
                    }
                }
            });
        });

        function openEditModal(id) {
            $.get(`?handler=Edit&id=${id}`, function (html) {
                $('#modalContainer').html(html);
                $('#editArticleModal').modal('show');
            });
        }

        $(document).on('submit', '#editArticleForm', function (e) {
            e.preventDefault();

            $.ajax({
                url: '?handler=Edit',
                type: 'POST',
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        $('#editArticleBody').html(res);
                        $.validator.unobtrusive.parse('#editArticleForm');
                    }
                }
            });
        });

    </script>

    <partial name="_ValidationScriptsPartial" />
}