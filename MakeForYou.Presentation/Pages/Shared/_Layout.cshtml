@using System.Security.Claims
@using MakeForYou.BusinessLogic.Entities.Enums
@{
    var isLoggedIn = User?.Identity?.IsAuthenticated == true;
    var name = User?.Identity?.Name ?? string.Empty;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MakeForYou</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Project styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/serif-theme.css" asp-append-version="true" />


    <!-- Serif Design System Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Source+Sans+3:wght@400;500;600&family=IBM+Plex+Mono:wght@500&display=swap" />

    <!-- Design Tokens -->
    <style>
            :root {
                --background: #FAFAF8;
                --foreground: #1A1A1A;
                --muted: #F5F3F0;
                --muted-foreground: #6B6B6B;
                --accent: #B8860B;
                --accent-secondary: #D4A84B;
                --border: #E8E4DF;
                --card: #FFFFFF;
            --clay: #c8855a;
            --bark: #5a3e2b;
            --cream: #fdf8f0;
            --mfy-ivory: #F9F7F2;
            --mfy-white: #FFFFFF;
            --mfy-clay: #C8855A;
            --mfy-clay-dark: #A3623C;
            --mfy-bark: #2D2926;
            --mfy-border: #E8E2D9;
            --serif: 'Playfair Display', serif;
            --sans: 'Source Sans 3', sans-serif;
            --mono: 'IBM Plex Mono', monospace;
            }

            body {
                font-family: 'Source Sans 3', 'Inter', sans-serif;
                background-color: var(--cream);
                color: var(--bark);
                line-height: 1.75;
            }

            .mfy-navbar {
                background-color: #fff;
                border-bottom: 1px solid #e8ddd0;
                padding: 0.8rem 0;
            }

            .mfy-logo {
                font-family: 'Playfair Display', serif;
                font-size: 1.5rem;
                font-weight: 700;
                color: var(--clay);
                text-decoration: none;
            }

                .mfy-logo span {
                    color: var(--bark);
                }

            .serif-heading {
                font-family: "Playfair Display", Georgia, serif;
                font-weight: normal;
                letter-spacing: -0.02em;
            }

            .small-caps {
                font-family: "IBM Plex Mono", monospace;
                font-size: 0.75rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
            }

            .rule {
                height: 1px;
                background: var(--border);
            }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <header class="mfy-header shadow-sm">
        <div class="container py-3 d-flex align-items-center justify-content-between">
            <a href="/" class="mfy-logo">Make<span>For</span>You<div class="dot"></div></a>

                <div class="d-flex align-items-center gap-3">
                    <a href="/Products" class="text-decoration-none text-dark">Browse</a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle rounded-pill px-3"
                                    type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                @if (User.IsInRole(nameof(UserRole.Seller)))
                                {
                                    <li>
                                        <a class="dropdown-item" href="/Seller/Dashboard">
                                            <i class="bi bi-grid me-2"></i>Dashboard
                                        </a>
                                    </li>
                                }
                                else
                                {
                                    <li>
                                        <a class="dropdown-item" href="/Buyer/Dashboard">
                                            <i class="bi bi-grid me-2"></i>Dashboard
                                        </a>
                                    </li>
                                }
                                <li>
                                    <a class="dropdown-item" href="/Orders">
                                        <i class="bi bi-bag me-2"></i>My Orders
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form method="post" action="/Auth/Logout">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Sign out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Auth/Login" class="btn btn-sm btn-outline-primary rounded-pill px-3">Sign in</a>
                        <a href="/Auth/Register" class="btn btn-sm btn-primary rounded-pill px-3">Register</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <footer class="text-center py-4 border-top mt-5">
        <div class="container">
            &copy; 2026 - MakeForYou - <span class="text-muted">Handmade with Heart</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>