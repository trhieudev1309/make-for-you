@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    // Giữ lại logic Session của bạn nhưng đổi tên cho chuyên nghiệp
    var name = HttpContextAccessor.HttpContext?.Session.GetString("AccountName");
    var isLoggedIn = !string.IsNullOrEmpty(name);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MakeForYou</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />

    <!-- Project styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Serif Design System Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&amp;family=Source+Sans+3:wght@400;500;600&amp;family=IBM+Plex+Mono:wght@500&amp;display=swap" />

    <!-- 🔥 Serif Design Tokens -->
    <style>
            :root {
                --background: #FAFAF8;
                --foreground: #1A1A1A;
                --muted: #F5F3F0;
                --muted-foreground: #6B6B6B;
                --accent: #B8860B;
                --accent-secondary: #D4A84B;
                --border: #E8E4DF;
                --card: #FFFFFF;
            --clay: #c8855a;
            --bark: #5a3e2b;
            --cream: #fdf8f0;
            }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--cream);
            color: var(--bark);
        }

        .mfy-navbar {
            background-color: #fff;
            border-bottom: 1px solid #e8ddd0;
            padding: 0.8rem 0;
        }

        .mfy-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--clay);
            text-decoration: none;
        }

            .mfy-logo span {
                color: var(--bark);
            }

            body {
                background-color: var(--background);
                color: var(--foreground);
                font-family: "Source Sans 3", system-ui, sans-serif;
                line-height: 1.75;
            }

            .serif-heading {
                font-family: "Playfair Display", Georgia, serif;
                font-weight: normal;
                letter-spacing: -0.02em;
            }

            .small-caps {
                font-family: "IBM Plex Mono", monospace;
                font-size: 0.75rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
            }

            .rule {
                height: 1px;
                background: var(--border);
            }
    </style>

    <!-- Page-specific styles -->
    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="mfy-navbar shadow-sm">
            <div class="container d-flex justify-content-between align-items-center">
                <a href="/" class="mfy-logo">Make<span>For</span>You</a>

                <div class="d-flex align-items-center gap-3">
                    <a href="/Products" class="text-decoration-none text-dark">Browse</a>
                    @if (isLoggedIn)
                    {
                        <span class="text-muted"><i class="bi bi-person-circle"></i> @name</span>
                        <a href="/Auth/Login?handler=Logout" class="btn btn-sm btn-outline-danger">Logout</a>
                    }
                    else
                    {
                        <a href="/Auth/Login" class="btn btn-sm btn-outline-primary">Login</a>
                    }
                </div>
            </div>
        </nav> 
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="text-center py-4 border-top mt-5">
        <div class="container">
            &copy; 2026 - MakeForYou - <span class="text-muted">Handmade with Heart</span>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>