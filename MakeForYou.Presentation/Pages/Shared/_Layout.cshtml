@using System.Security.Claims
@{
    var isLoggedIn = User?.Identity?.IsAuthenticated == true;
    var name = User?.Identity?.Name ?? string.Empty;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MakeForYou</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Project styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/serif-theme.css" asp-append-version="true" />


    <!-- Serif Design System Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Source+Sans+3:wght@400;500;600&family=IBM+Plex+Mono:wght@500&display=swap" />

    <!-- Design Tokens -->
    <style>
            :root {
                --background: #FAFAF8;
                --foreground: #1A1A1A;
                --muted: #F5F3F0;
                --muted-foreground: #6B6B6B;
                --accent: #B8860B;
                --accent-secondary: #D4A84B;
                --border: #E8E4DF;
                --card: #FFFFFF;
            --clay: #c8855a;
            --bark: #5a3e2b;
            --cream: #fdf8f0;
            --mfy-ivory: #F9F7F2;
            --mfy-white: #FFFFFF;
            --mfy-clay: #C8855A;
            --mfy-clay-dark: #A3623C;
            --mfy-bark: #2D2926;
            --mfy-border: #E8E2D9;
            --serif: 'Playfair Display', serif;
            --sans: 'Source Sans 3', sans-serif;
            --mono: 'IBM Plex Mono', monospace;
            }

        body {
            font-family: var(--sans);
            background-color: var(--mfy-ivory);
            color: var(--mfy-bark);
            margin: 0;
        }
        /* ── LOGO MAKEFORYOU ── */
        .mfy-logo {
            font-family: var(--serif);
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--mfy-bark);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .mfy-logo .dot {
                width: 8px;
                height: 8px;
                background: var(--mfy-clay);
                border-radius: 50%;
                display: inline-block;
                margin-top: 10px;
            }

            .mfy-logo span {
                font-weight: 400;
                font-style: italic;
                color: var(--mfy-clay);
            }

        /* ── HEADER & NAVIGATION ── */
        .mfy-header {
            background: white;
            border-bottom: 1px solid var(--mfy-border);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .mfy-navbar {
            background-color: #fff;
            border-bottom: 1px solid #e8ddd0;
            padding: 0.8rem 0;
        }

        .search-container {
            flex-grow: 1;
            max-width: 500px;
            margin: 0 2rem;
            position: relative;
        }

        .search-input {
            width: 100%;
            padding: 0.5rem 1.2rem;
            border-radius: 50px;
            border: 1px solid var(--mfy-border);
            background: var(--mfy-ivory);
            font-size: 0.9rem;
            transition: 0.3s;
        }

            .search-input:focus {
                border-color: var(--mfy-clay);
                outline: none;
                background: white;
                box-shadow: 0 0 0 4px rgba(200, 133, 90, 0.1);
            }
        .mfy-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--clay);
            text-decoration: none;
        }

                .mfy-logo span {
                    color: var(--bark);
                }

            .serif-heading {
                font-family: "Playfair Display", Georgia, serif;
                font-weight: normal;
                letter-spacing: -0.02em;
            }

            .small-caps {
                font-family: "IBM Plex Mono", monospace;
                font-size: 0.75rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
            }

            .rule {
                height: 1px;
                background: var(--border);
            }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <header class="mfy-header shadow-sm">
        <div class="container py-3 d-flex align-items-center justify-content-between">
            <a href="/" class="mfy-logo">Make<span>For</span>You<div class="dot"></div></a>

            <div class="search-container d-none d-lg-block">
                <form method="get" action="/Products">
                    <input type="text" name="SearchTerm" class="search-input" placeholder="Search for unique handmade items...">
                </form>
            </div>

            <div class="d-flex align-items-center gap-4">
                <a href="/Products" class="text-dark text-decoration-none fw-medium d-none d-md-block">Browse</a>
                @if (isLoggedIn)
                {
                    <a asp-page="/Profile/Index" class="text-dark text-decoration-none d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle"></i> @name
                    </a>
                    <form method="post" asp-page="/Auth/Logout" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Logout</button>
                    </form>
                }
                else
                {
                    <a href="/Auth/Login" class="btn btn-outline-dark rounded-pill px-4 fw-medium">Sign in</a>
                }
                <a href="#" class="fs-4 text-dark"><i class="bi bi-bag-heart"></i></a>
            </div>
        </div>
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <footer class="text-center py-4 border-top mt-5">
        <div class="container">
            &copy; 2026 - MakeForYou - <span class="text-muted">Handmade with Heart</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>