@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    // Giữ lại logic Session của bạn nhưng đổi tên cho chuyên nghiệp
    var name = HttpContextAccessor.HttpContext?.Session.GetString("AccountName");
    var isLoggedIn = !string.IsNullOrEmpty(name);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MakeForYou</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --clay: #c8855a;
            --bark: #5a3e2b;
            --cream: #fdf8f0;
        }
        body { font-family: 'Inter', sans-serif; background-color: var(--cream); color: var(--bark); }
        .mfy-navbar { background-color: #fff; border-bottom: 1px solid #e8ddd0; padding: 0.8rem 0; }
        .mfy-logo { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: var(--clay); text-decoration: none; }
        .mfy-logo span { color: var(--bark); }
    </style>
</head>
<body>
    <header>
        <nav class="mfy-navbar shadow-sm">
            <div class="container d-flex justify-content-between align-items-center">
                <a href="/" class="mfy-logo">Make<span>For</span>You</a>
                
                <div class="d-flex align-items-center gap-3">
                    <a href="/Products" class="text-decoration-none text-dark">Browse</a>
                    @if (isLoggedIn)
                    {
                        <span class="text-muted"><i class="bi bi-person-circle"></i> @name</span>
                        <a href="/Auth/Login?handler=Logout" class="btn btn-sm btn-outline-danger">Logout</a>
                    }
                    else
                    {
                        <a href="/Auth/Login" class="btn btn-sm btn-outline-primary">Login</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="text-center py-4 border-top mt-5">
        <div class="container">
            &copy; 2026 - MakeForYou - <span class="text-muted">Handmade with Heart</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>