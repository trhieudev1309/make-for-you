@page
@model MakeForYou.Presentation.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Tạo Tài Khoản";
}

<!-- Page-specific styles -->
<style>
    .auth-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(26, 26, 26, 0.06);
    }

    .form-control {
        border-color: var(--border);
        border-radius: 6px;
        padding: 0.85rem 1rem;
        font-size: 1.05rem;
        transition: all 0.2s ease;
    }

        .form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(184, 134, 11, 0.15);
        }

    .btn-register {
        background-color: var(--accent);
        color: white;
        border: none;
        padding: 0.85rem 1.5rem;
        font-size: 1.05rem;
        font-weight: 500;
        border-radius: 6px;
        transition: all 0.2s ease;
    }

        .btn-register:hover {
            background-color: var(--accent-secondary);
            transform: translateY(-1px);
        }

    .form-check-input:checked {
        background-color: var(--accent);
        border-color: var(--accent);
    }
</style>

<div class="min-vh-100 d-flex align-items-center py-5">
    <div class="container">
        <div class="mx-auto" style="max-width: 480px;">

            <div class="auth-card p-5 p-md-6">

                <!-- Editorial Section Label -->
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="flex-grow-1 h-px" style="background: var(--border);"></div>
                    <span class="small-caps">Tham Gia Cùng Chúng Tôi</span>
                    <div class="flex-grow-1 h-px" style="background: var(--border);"></div>
                </div>

                <!-- Headline -->
                <h1 class="serif-heading display-5 mb-2 text-center" style="color: var(--foreground);">
                    Tạo Tài Khoản
                </h1>
                <p class="text-center mb-5" style="color: var(--muted-foreground);">
                    Tham gia MakeForYou với tư cách Người mua hoặc Người bán
                </p>

                <!-- Error Message -->
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert mb-4" style="background:#F8E8E8; color:#9F2B2B; border:1px solid #E8E4DF;">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        @Model.ErrorMessage
                    </div>
                }

                <!-- Success Message -->
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert mb-4" style="background:#F0EDE6; color:#1A1A1A; border:1px solid #E8E4DF;">
                        <i class="bi bi-check-circle me-2"></i>
                        @Model.SuccessMessage
                    </div>
                }

                <form method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Full Name -->
                    <div class="mb-4">
                        <label asp-for="Input.FullName" class="form-label small-caps">Họ và Tên</label>
                        <input asp-for="Input.FullName" class="form-control" placeholder="Nguyen Van A" />
                        <span asp-validation-for="Input.FullName" class="text-danger small mt-1"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label small-caps">Địa chỉ Email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="example@email.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small mt-1"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label small-caps">Mật khẩu</label>
                        <div class="input-group">
                            <input asp-for="Input.Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="••••••••"
                                   id="passwordInput" />
                            <button class="btn border"
                                    type="button"
                                    style="border-color: var(--border);"
                                    onclick="togglePassword()">
                                <i class="bi bi-eye" id="eyeIcon" style="font-size: 1.1rem;"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small mt-1"></span>
                        <div class="form-text small" style="color: var(--muted-foreground);">
                            8–15 ký tự · chữ hoa · chữ thường · chữ số · ký tự đặc biệt
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-5">
                        <label asp-for="Input.ConfirmPassword" class="form-label small-caps">Xác nhận Mật khẩu</label>
                        <div class="input-group">
                            <input asp-for="Input.ConfirmPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Nhập lại mật khẩu của bạn"
                                   id="confirmPasswordInput" />
                            <button class="btn border"
                                    type="button"
                                    style="border-color: var(--border);"
                                    onclick="toggleConfirm()">
                                <i class="bi bi-eye" id="eyeIconConfirm" style="font-size: 1.1rem;"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1"></span>
                    </div>

                    <!-- Phone -->
                    <div class="mb-4">
                        <label asp-for="Input.Phone" class="form-label small-caps">Số điện thoại</label>
                        <input asp-for="Input.Phone" class="form-control" placeholder="0912345678" />
                        <span asp-validation-for="Input.Phone" class="text-danger small mt-1"></span>
                    </div>

                    <!-- Role Selection -->
                    <div class="mb-5">
                        <label class="form-label small-caps">Đăng ký với tư cách</label>
                        <div class="d-flex gap-4 mt-2">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="Input.Role" value="0" id="roleBuyer" checked />
                                <label class="form-check-label" for="roleBuyer">
                                    <i class="bi bi-bag me-1"></i>Người mua
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="Input.Role" value="1" id="roleSeller" />
                                <label class="form-check-label" for="roleSeller">
                                    <i class="bi bi-tools me-1"></i>Người bán
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="Input.Role" class="text-danger small mt-1"></span>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="btn btn-register w-100">
                        Tạo Tài Khoản
                    </button>
                </form>

                <!-- Divider -->
                <div class="d-flex align-items-center gap-3 my-5">
                    <div class="flex-grow-1 h-px" style="background: var(--border);"></div>
                    <span class="small-caps" style="color: var(--muted-foreground);">hoặc</span>
                    <div class="flex-grow-1 h-px" style="background: var(--border);"></div>
                </div>

                <!-- Login Link -->
                <p class="text-center" style="color: var(--muted-foreground);">
                    Đã có tài khoản?
                    <a asp-page="/Auth/Login"
                           style="color: var(--accent); font-weight: 500; text-decoration: none;">
                        Đăng nhập
                    </a>
                </p>

            </div>

            <!-- Footer note -->
            <p class="text-center mt-5 small" style="color: var(--muted-foreground);">
                &copy; 2026 — FUNews
            </p>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('eyeIcon');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }

        function toggleConfirm() {
            const input = document.getElementById('confirmPasswordInput');
            const icon = document.getElementById('eyeIconConfirm');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}