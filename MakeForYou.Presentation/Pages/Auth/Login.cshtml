@page
@model FUNews.Presentation.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5 animate-fade">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow border-0">

            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <h4 class="fw-semibold mb-1">FUNews</h4>
                    <p class="text-muted mb-0">Management System Login</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.Login?.ErrorMessage))
                {
                    <div class="alert alert-danger text-center animate-shake">
                        @Model.Login?.ErrorMessage
                    </div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Login.Email" class="form-label"></label>
                        <input asp-for="Login.Email"
                               class="form-control"
                               placeholder="Enter your email" />
                        <span asp-validation-for="Login.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Login.Password" class="form-label"></label>
                        <input asp-for="Login.Password"
                               class="form-control"
                               placeholder="Enter your password" />
                        <span asp-validation-for="Login.Password" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            Login
                        </button>
                    </div>
                </form>
            </div>

            <div class="card-footer text-center text-muted small">
                © 2026 FUNews
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
