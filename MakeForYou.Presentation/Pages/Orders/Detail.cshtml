@page "{id:long}"
@model MakeForYou.Presentation.Pages.Orders.DetailModel
@using MakeForYou.BusinessLogic.Enums
@{
    ViewData["Title"] = $"Order #{Model.Order?.OrderId}";
}

<div class="container py-5" style="max-width: 860px;">

    @if (Model.Order == null)
    {
        <div class="alert alert-warning">Order not found.</div>
    }
    else
    {
        <!-- Breadcrumb -->
        <nav class="mb-4">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item"><a asp-page="/Orders/Index" class="text-decoration-none">My Orders</a></li>
                <li class="breadcrumb-item active">Order #@Model.Order.OrderId</li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
            <div>
                <h2 class="fw-bold mb-1" style="font-family: var(--serif);">Order #@Model.Order.OrderId</h2>
                <div class="text-muted small">Placed on @Model.Order.CreatedAt.ToLocalTime().ToString("MMMM d, yyyy 'at' HH:mm")</div>
            </div>
            <span class="badge rounded-pill @MakeForYou.Presentation.Pages.Orders.DetailModel.BadgeClass(Model.Order.Status) px-3 py-2 fs-6">
                <i class="bi @MakeForYou.Presentation.Pages.Orders.DetailModel.StatusIcon(Model.Order.Status) me-1"></i>
                @((OrderStatus)Model.Order.Status)
            </span>
        </div>

        <div class="row g-4">

            <!-- LEFT COLUMN -->
            <div class="col-lg-8">

                <!-- Order description -->
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3"><i class="bi bi-file-text me-2 text-muted"></i>Order Description</h6>
                        <p class="mb-0 text-muted">
                            @(string.IsNullOrEmpty(Model.Order.OrderDescription) ? "No description provided." : Model.Order.OrderDescription)
                        </p>
                    </div>
                </div>

                <!-- Quotations -->
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3"><i class="bi bi-tag me-2 text-muted"></i>Quotations</h6>
                        @if (Model.Order.Quotations == null || !Model.Order.Quotations.Any())
                        {
                            <p class="text-muted mb-0 fst-italic">No quotations yet. The artisan will send one shortly.</p>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3">
                                @foreach (var q in Model.Order.Quotations.OrderByDescending(q => q.CreatedAt))
                                {
                                    <div class="p-3 rounded-3" style="background: var(--mfy-ivory, #F9F7F2); border: 1px solid #E8E2D9;">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <div class="fw-bold fs-5">
                                                    @(q.ProposedPrice.HasValue ? q.ProposedPrice.Value.ToString("N0") + " VNĐ" : "Price TBD")
                                                </div>
                                                <div class="text-muted small">@q.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</div>
                                            </div>
                                            <span class="badge @(q.Status == 1 ? "bg-success" : "bg-secondary") rounded-pill">
                                                @(q.Status == 1 ? "Accepted" : "Pending")
                                            </span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(q.Message))
                                        {
                                            <p class="mt-2 mb-0 small text-muted">@q.Message</p>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Chat messages -->
                <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3"><i class="bi bi-chat-dots me-2 text-muted"></i>Messages</h6>
                        @if (Model.Order.ChatMessages == null || !Model.Order.ChatMessages.Any())
                        {
                            <p class="text-muted mb-0 fst-italic">No messages yet.</p>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3" style="max-height: 360px; overflow-y: auto;">
                                @foreach (var msg in Model.Order.ChatMessages)
                                {
                                    var isMine = msg.SenderId == Model.Order.BuyerId;
                                    <div class="d-flex @(isMine ? "justify-content-end" : "justify-content-start")">
                                        <div class="p-3 rounded-3 small" style="max-width: 75%; background: @(isMine ? "#2D2926" : "#F0EDE8"); color: @(isMine ? "white" : "inherit");">
                                            <div class="fw-bold mb-1" style="font-size: 0.7rem; opacity: 0.7;">@msg.Sender?.FullName</div>
                                            @msg.MessageContent
                                            <div class="mt-1 text-end" style="font-size: 0.65rem; opacity: 0.55;">@msg.SentAt.ToLocalTime().ToString("HH:mm")</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- RIGHT COLUMN -->
            <div class="col-lg-4">

                <!-- Summary card -->
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3">Order Summary</h6>
                        <div class="d-flex justify-content-between small text-muted mb-2">
                            <span>Status</span>
                            <span class="fw-bold text-dark">@((OrderStatus)Model.Order.Status)</span>
                        </div>
                        <div class="d-flex justify-content-between small text-muted mb-2">
                            <span>Agreed price</span>
                            <span class="fw-bold text-dark">
                                @(Model.Order.AgreedPrice.HasValue ? Model.Order.AgreedPrice.Value.ToString("N0") + " VNĐ" : "—")
                            </span>
                        </div>
                        @if (Model.Order.CompletedAt.HasValue)
                        {
                            <div class="d-flex justify-content-between small text-muted mb-2">
                                <span>Completed</span>
                                <span class="fw-bold text-dark">@Model.Order.CompletedAt.Value.ToLocalTime().ToString("MMM d, yyyy")</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Artisan card -->
                <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3">Artisan</h6>
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                 style="width:44px;height:44px;background:#2D2926;font-size:1.1rem;">
                                @(Model.Order.Seller?.User?.FullName?.Substring(0, 1).ToUpper())
                            </div>
                            <div>
                                <div class="fw-bold">@Model.Order.Seller?.User?.FullName</div>
                                <div class="text-muted small">@Model.Order.Seller?.SkillDescription</div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Order.Seller?.User?.Email))
                        {
                            <a href="mailto:@Model.Order.Seller.User.Email" class="btn btn-dark w-100 rounded-pill btn-sm">
                                <i class="bi bi-envelope me-1"></i>Contact Artisan
                            </a>
                        }
                    </div>
                </div>

            </div>
        </div>
    }
</div>