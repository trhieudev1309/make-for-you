@page "{id:int}"
@using FUNews.Presentation.Pages.Lecturer.Home
@model FUNews.Presentation.Pages.Lecturer.Home.ArticleModel

@{
    ViewData["Title"] = Model.Article?.NewsTitle;
}

<style>
    /* Page animation */
    .article-wrapper {
        animation: fadeUp 0.6s ease;
    }

    

    /* Card style */
    .article-card {
        border-radius: 14px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.06);
    }

    /* Article content */
    .article-content {
        line-height: 1.7;
        font-size: 1.05rem;
    }

    /* Tag animation */
    .tag-badge {
        transition: transform 0.2s ease, background-color 0.2s ease;
        cursor: default;
    }

        .tag-badge:hover {
            transform: translateY(-2px);
            background-color: #495057 !important;
        }

    /* Related articles hover */
    .related-item {
        transition: background-color 0.2s ease, padding-left 0.2s ease;
    }

        .related-item:hover {
            background-color: #f8f9fa;
            padding-left: 1.25rem;
        }

    /* Button polish */
    .btn {
        border-radius: 8px;
    }
</style>

<div class="container mt-4 article-wrapper">
    <div class="card article-card">
        <div class="card-body">

            <h2 class="mb-2">@Model.Article?.NewsTitle</h2>

            <p class="text-muted mb-3">
                Category:
                <strong>@Model.Article?.Category?.CategoryName</strong> |
                Created:
                @Model.Article?.CreatedDate?.ToString("dd/MM/yyyy")
            </p>

            <hr />

            <div class="article-content mb-4">
                @Html.Raw(Model.Article?.NewsContent)
            </div>

            @if (Model.Article?.Tags != null && Model.Article.Tags.Any())
            {
                <div class="mb-4">
                    <strong>Tags:</strong>
                    <div class="mt-2">
                        @foreach (var tag in Model.Article.Tags)
                        {
                            <span class="badge bg-secondary me-1 tag-badge">
                                @tag.TagName
                            </span>
                        }
                    </div>
                </div>
            }

            <hr />

            <h5 class="mb-3">Related Articles</h5>

            @if (Model.RelatedArticles.Any())
            {
                <ul class="list-group list-group-flush mb-3">
                    @foreach (var a in Model.RelatedArticles)
                    {
                        <li class="list-group-item related-item">
                            <a asp-page="./Details"
                               asp-route-id="@a.NewsArticleId"
                               class="text-decoration-none">
                                @a.NewsTitle
                            </a>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">
                    No related articles found.
                </p>
            }

            <a asp-page="./Index"
               class="btn btn-outline-secondary mt-2">
                ← Back to News
            </a>

        </div>
    </div>
</div>
