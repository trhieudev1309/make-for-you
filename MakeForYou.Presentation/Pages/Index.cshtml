@page
@model MakeForYou.Presentation.Pages.IndexModel
@{
    ViewData["Title"] = "MakeForYou – Handcrafted Marketplace";
    Layout = null; 
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --mfy-ivory: #F9F7F2;
            --mfy-white: #FFFFFF;
            --mfy-clay: #C8855A;
            --mfy-clay-dark: #A3623C;
            --mfy-bark: #2D2926;
            --mfy-border: #E8E2D9;
            --serif: 'Playfair Display', serif;
            --sans: 'Source Sans 3', sans-serif;
            --mono: 'IBM Plex Mono', monospace;
        }

        body { font-family: var(--sans); background-color: var(--mfy-ivory); color: var(--mfy-bark); margin: 0; }

        .mfy-logo { 
            font-family: var(--serif); font-size: 1.8rem; font-weight: 700; 
            color: var(--mfy-bark); text-decoration: none; 
            display: flex; align-items: center; gap: 4px;
        }
        .mfy-logo .dot { width: 8px; height: 8px; background: var(--mfy-clay); border-radius: 50%; display: inline-block; margin-top: 10px; }
        .mfy-logo span { font-weight: 400; font-style: italic; color: var(--mfy-clay); }

        .mfy-header { background: white; border-bottom: 1px solid var(--mfy-border); position: sticky; top: 0; z-index: 1000; }
        
        /* --- FIX LỖI THANH CUỘN NGANG --- */
        .quick-nav { 
            display: flex; 
            justify-content: center; 
            gap: 1.5rem; 
            padding: 1rem 0; 
            background: white; 
            flex-wrap: wrap; /* Cho phép xuống hàng thay vì hiện thanh cuộn */
        }
        .quick-nav a { 
            font-family: var(--mono); 
            font-size: 0.65rem; 
            text-transform: uppercase; 
            letter-spacing: 0.15em; 
            text-decoration: none; 
            color: #888; 
            transition: 0.3s;
            padding: 5px 0;
        }
        .quick-nav a:hover { color: var(--mfy-clay); }

        .search-container { flex-grow: 1; max-width: 500px; margin: 0 2rem; position: relative; }
        .search-input { width: 100%; padding: 0.5rem 1.2rem; border-radius: 50px; border: 1px solid var(--mfy-border); background: var(--mfy-ivory); font-size: 0.9rem; transition: 0.3s; }
        .search-input:focus { border-color: var(--mfy-clay); outline: none; background: white; box-shadow: 0 0 0 4px rgba(200, 133, 90, 0.1); }

        .hero-banner { 
            border-radius: 24px; overflow: hidden; min-height: 480px; position: relative;
            display: flex; align-items: center; padding: 5rem; color: white;
            background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.2)), url('https://images.unsplash.com/photo-1459411552884-841db9b3cc2a?auto=format&fit=crop&w=1400');
            background-size: cover; background-position: center;
            animation: fadeIn 1s ease;
        }
        .hero-content { max-width: 550px; }
        .hero-content h1 { font-family: var(--serif); font-size: 4rem; font-weight: 700; line-height: 1.1; margin-bottom: 1.5rem; text-shadow: 0 2px 10px rgba(0,0,0,0.2); }
        
        .btn-mfy-solid { background: var(--mfy-clay); color: white; padding: 1rem 2.5rem; border-radius: 50px; text-decoration: none; font-weight: 600; display: inline-block; transition: 0.3s; box-shadow: 0 4px 15px rgba(200, 133, 90, 0.3); }
        .btn-mfy-solid:hover { background: var(--mfy-clay-dark); transform: translateY(-3px); box-shadow: 0 6px 20px rgba(200, 133, 90, 0.4); color: white; }

        .custom-section { 
            background: #1A1A1A; color: white; padding: 6rem 0; border-radius: 32px; margin: 5rem 0; 
            position: relative; overflow: hidden;
        }
        .custom-tag { font-family: var(--mono); color: var(--mfy-clay); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.4em; margin-bottom: 1.2rem; display: block; }

        .product-card { background: white; border: 1px solid var(--mfy-border); border-radius: 16px; overflow: hidden; height: 100%; transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); }
        .product-card:hover { transform: translateY(-12px); box-shadow: 0 25px 50px rgba(0,0,0,0.1); border-color: var(--mfy-clay); }
        .product-img { height: 280px; object-fit: cover; width: 100%; transition: 0.6s; }

        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body>

<header class="mfy-header shadow-sm">
    <div class="container py-3 d-flex align-items-center justify-content-between">
        <a href="/" class="mfy-logo">Make<span>For</span>You<div class="dot"></div></a>
        
        <div class="search-container d-none d-lg-block">
            <form method="get" action="/Products">
                <input type="text" name="SearchTerm" class="search-input" placeholder="Search for unique handmade items..." value="@Model.SearchTerm">
            </form>
        </div>

        <div class="d-flex align-items-center gap-4">
            <a href="/Products" class="text-dark text-decoration-none fw-medium d-none d-md-block">Browse</a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="dropdown">
                    <button class="btn btn-outline-dark rounded-pill px-4 fw-medium dropdown-toggle"
                            type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                        <li><a class="dropdown-item" href="/@(User.IsInRole("Seller") ? "Seller" : "Buyer")/Dashboard"><i class="bi bi-grid me-2"></i>Dashboard</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form method="post" action="/Auth/Logout">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Sign out
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <a href="/Auth/Login" class="btn btn-outline-dark rounded-pill px-4 fw-medium">Sign in</a>
            }

            <a href="/Cart" class="position-relative text-dark fs-4 ms-2">
                <i class="bi bi-bag-heart"></i>
                <span id="cartBadgeCount" class="position-absolute top-0 start-100 translate-middle badge rounded-circle bg-dark" 
                      style="font-size: 0.55rem; padding: 0.35em 0.5em;">
                    @Model.CartCount
                </span>
            </a>
        </div>
    </div>
    
    <div class="container border-top d-none d-md-block">
        <nav class="quick-nav">
            @* --- FIX LỖI TRÙNG CATEGORY BẰNG DISTINCTBY --- *@
            @foreach(var cat in Model.Categories.DistinctBy(c => c.Name))
            {
                <a href="/Products?categoryId=@cat.CategoryId">@cat.Name</a>
            }
        </nav>
    </div>
</header>

<main class="container mt-5">
    <section class="hero-banner shadow-lg mb-5">
        <div class="hero-content">
            <h1>Elevate your space with soul.</h1>
            <p class="lead mb-5 opacity-90">Experience the beauty of handcrafted goods. Every piece is a testament to human creativity and passion.</p>
            <a href="/Products" class="btn-mfy-solid">Explore Gallery</a>
        </div>
    </section>

    <section class="custom-section text-center shadow-lg">
        <div class="container position-relative" style="z-index: 2;">
            <span class="custom-tag">Premium Custom Service</span>
            <h2 class="display-4 fw-bold mb-4" style="font-family: var(--serif);">Can't find exactly what you need?</h2>
            <p class="opacity-75 mb-5 mx-auto fs-5" style="max-width: 650px;">Collaborate with our world-class artisans to create a masterpiece that is uniquely yours.</p>
            <a href="/CustomOrders/Create" class="btn btn-light rounded-pill px-5 py-3 fw-bold shadow">
                Start Custom Project <i class="bi bi-stars ms-2 text-warning"></i>
            </a>
        </div>
    </section>

    <div class="d-flex justify-content-between align-items-end my-5">
        <div>
            <h2 style="font-family: var(--serif); font-weight: 700; font-size: 2.5rem;">Editor's Picks</h2>
            <p class="text-muted">Handpicked treasures from our artisan community.</p>
        </div>
        <a href="/Products" class="text-clay text-decoration-none fw-bold border-bottom border-2 border-clay pb-1">See all creations</a>
    </div>

    <div class="row g-4 mb-5">
        @foreach (var product in Model.Products)
        {
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="product-card">
                    <div style="overflow: hidden; position: relative;">
                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.jpg" : product.ImageUrl)" class="product-img" alt="@product.Title" />
                    </div>
                    <div class="p-4">
                        <span class="text-uppercase text-clay fw-bold" style="font-size: 0.65rem; letter-spacing: 0.1em;">@product.Category?.Name</span>
                        <h5 class="fw-bold my-2 text-truncate" style="font-family: var(--serif);">@product.Title</h5>
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <span class="fw-bold fs-5">@product.Price?.ToString("N0") VNĐ</span>
                            <a asp-page="/Products/Details" asp-route-id="@product.ProductId" class="btn btn-dark btn-sm rounded-pill px-4">View</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</main>

<footer class="py-5" style="background: var(--mfy-bark); color: white; margin-top: 8rem;">
    <div class="container text-center">
        <a href="/" class="mfy-logo text-white justify-content-center mb-4" style="font-size: 2rem;">Make<span>For</span>You<div class="dot"></div></a>
        <p class="small opacity-50">Handcrafted with Heart &middot; 2026</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>