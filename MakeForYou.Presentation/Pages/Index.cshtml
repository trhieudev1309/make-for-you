@page
@model MakeForYou.Presentation.Pages.IndexModel
@{
	ViewData["Title"] = "MakeForYou – Sàn thương mại điện tử đồ thủ công";
}

<style>
	/* ── CẢI TIẾN THANH PHÂN LOẠI DANH MỤC (QUICK NAV) ── */
	.quick-nav-wrapper {
		border-top: 1px solid rgba(0, 0, 0, 0.05);
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		background-color: #fbfbfb;
		width: 100%;
	}

	.quick-nav {
		display: flex;
		justify-content: center;
		gap: 3.5rem;
		padding: 1.1rem 0;
		overflow-x: auto;
		white-space: nowrap;
		scrollbar-width: none;
	}

		.quick-nav::-webkit-scrollbar {
			display: none;
		}

		.quick-nav a {
			font-family: var(--sans, sans-serif);
			font-size: 0.85rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			text-decoration: none;
			color: #333333;
			position: relative;
			padding: 0.25rem 0;
			transition: color 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		}

			.quick-nav a::after {
				content: "";
				position: absolute;
				bottom: 0;
				left: 0;
				width: 0;
				height: 2px;
				background-color: var(--mfy-clay, #C8855A);
				transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.quick-nav a:hover {
				color: var(--mfy-clay, #C8855A) !important;
			}

				.quick-nav a:hover::after {
					width: 100%;
				}

	/* ── HERO BANNER ── */
	.hero-banner {
		border-radius: 24px;
		overflow: hidden;
		height: 480px;
		position: relative;
		display: flex;
		align-items: center;
		padding: 5rem;
		color: white;
		background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.2)), url('https://images.unsplash.com/photo-1459411552884-841db9b3cc2a?auto=format&fit=crop&w=1400');
		background-size: cover;
		background-position: center;
		animation: fadeIn 1s ease;
	}

	.hero-content {
		max-width: 550px;
	}

		.hero-content h1 {
			font-family: var(--serif);
			font-size: 3.5rem;
			font-weight: 700;
			line-height: 1.15;
			margin-bottom: 1.5rem;
			text-shadow: 0 2px 10px rgba(0,0,0,0.2);
		}

	.btn-mfy-solid {
		background: var(--mfy-clay);
		color: white;
		padding: 1rem 2.5rem;
		border-radius: 50px;
		text-decoration: none;
		font-weight: 600;
		display: inline-block;
		transition: 0.3s;
		box-shadow: 0 4px 15px rgba(200, 133, 90, 0.3);
	}

		.btn-mfy-solid:hover {
			background: var(--mfy-clay-dark);
			transform: translateY(-3px);
			box-shadow: 0 6px 20px rgba(200, 133, 90, 0.4);
			color: white;
		}

	/* ── CUSTOMIZE SECTION ── */
	.custom-section {
		background: #1A1A1A;
		color: white;
		padding: 6rem 0;
		border-radius: 32px;
		margin: 5rem 0;
		position: relative;
		overflow: hidden;
	}

		.custom-section::after {
			content: "";
			position: absolute;
			top: 0;
			right: 0;
			width: 300px;
			height: 300px;
			background: radial-gradient(circle, rgba(200, 133, 90, 0.1) 0%, transparent 70%);
		}

	.custom-tag {
		font-family: var(--mono);
		color: var(--mfy-clay);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.4em;
		margin-bottom: 1.2rem;
		display: block;
	}

	/* ── PRODUCT CARDS (CẬP NHẬT KỸ THUẬT WRAPPER CHỐNG RUNG) ── */
	.card-wrapper {
		height: 100%;
		display: block;
	}

	.product-card {
		background: white;
		border: 1px solid var(--mfy-border);
		border-radius: 16px;
		overflow: hidden;
		height: 100%;
		transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	.card-wrapper:hover .product-card {
		transform: translateY(-12px);
		box-shadow: 0 25px 50px rgba(0,0,0,0.1);
		border-color: var(--mfy-clay);
	}

	.product-img {
		height: 280px;
		object-fit: cover;
		width: 100%;
		transition: 0.6s;
	}

	.card-wrapper:hover .product-img {
		transform: scale(1.05);
	}

	/* Responsive */
	@@media (max-width: 768px) {
		.hero-banner {
			height: auto;
			padding: 3rem 1.5rem;
			text-align: center;
		}

		.hero-content h1 {
			font-size: 2rem;
		}

		.hero-content .lead {
			font-size: 1rem;
		}

		.quick-nav {
			gap: 1.8rem;
			justify-content: flex-start;
			padding: 1rem 1rem;
		}

		.custom-section {
			padding: 3rem 1.5rem;
			margin: 2rem 0;
			border-radius: 16px;
		}

		.custom-section .display-5 {
			font-size: 1.6rem;
		}

		.custom-section .fs-5 {
			font-size: 0.95rem !important;
		}

		.product-img {
			height: 200px;
		}

		.d-flex.justify-content-between.align-items-end h2 {
			font-size: 1.5rem !important;
		}
	}
</style>
<body>

	@* THANH PHÂN LOẠI - Dynamic from DB *@
	<div class="quick-nav-wrapper d-none d-md-block">
		<div class="container">
			<nav class="quick-nav">
				<a href="/Products">Tất cả</a>
				@foreach (var cat in Model.Categories)
				{
					<a href="/Products?categoryId=@cat.CategoryId">@cat.Name</a>
				}
			</nav>
		</div>
	</div>

	<div class="container mt-3">
		@* THANH TÌM KIẾM *@
		<style>
			.home-search-bar {
				padding: 4px;
				transition: all 0.3s ease;
			}
			.home-search-bar:focus-within {
				box-shadow: 0 6px 20px rgba(0,0,0,0.08) !important;
				border-color: rgba(200, 133, 90, 0.4) !important;
			}
			.home-search-input {
				font-family: var(--sans, sans-serif);
				font-size: 0.95rem;
				padding: 0.4rem 0.5rem;
			}
			.home-search-btn {
				background-color: var(--mfy-clay, #C8855A);
				color: white;
				font-weight: 600;
				font-size: 0.9rem;
				padding: 0.4rem 1.8rem;
				transition: all 0.3s ease;
			}
			.home-search-btn:hover {
				background-color: #b0724a;
				color: white;
			}
		</style>
		<div class="row justify-content-center mb-4">
			<div class="col-md-7 col-lg-6">
				<form action="/Products" method="get" class="d-flex bg-white rounded-pill shadow-sm border home-search-bar align-items-center">
					<i class="bi bi-search ms-4 text-muted" style="font-size: 1rem;"></i>
					<input type="text" name="searchTerm" class="form-control border-0 shadow-none bg-transparent home-search-input ms-2" placeholder="Tìm kiếm sản phẩm, người bán...">
					<button class="btn rounded-pill home-search-btn" type="submit">
						Tìm
					</button>
				</form>
			</div>
		</div>

		@* HERO BANNER *@
		<section class="hero-banner shadow-lg mb-5">
			<div class="hero-content">
				<h1>Nâng tầm không gian sống bằng cả tâm hồn.</h1>
				<p class="lead mb-5 opacity-90">Trải nghiệm vẻ đẹp tinh tế từ các sản phẩm thủ công. Mỗi tác phẩm là một minh chứng rõ nét cho sự sáng tạo và niềm đam mê sáng tạo của con người.</p>
				<a href="/Products" class="btn-mfy-solid">Khám phá ngay</a>
			</div>
		</section>

		@* ========================================= *@
		@* 🏆 SẢN PHẨM BÁN CHẠY NHẤT (BEST SELLERS) 🏆 *@
		@* ========================================= *@
		<div class="d-flex justify-content-between align-items-end mb-4 pt-3">
			<div>
				<h2 style="font-family: var(--serif); font-weight: 700; font-size: 2.2rem;">Sản phẩm bán chạy nhất</h2>
				<p class="text-muted">Những tuyệt tác thủ công được cộng đồng yêu thích và lựa chọn nhiều nhất.</p>
			</div>
			<a href="/Products" class="text-decoration-none fw-bold border-bottom border-2 pb-1" style="color: var(--mfy-clay);">Khám phá thêm</a>
		</div>

		<div class="row g-4 mb-5">
			@if (Model.BestSellers != null && Model.BestSellers.Any())
			{
				@foreach (var product in Model.BestSellers)
				{
					<div class="col-6 col-md-4 col-lg-3">
						@* BỌC CARD VÀO WRAPPER CHỐNG RUNG LẮC *@
						<div class="card-wrapper">
							<div class="product-card">
								<div style="overflow: hidden; position: relative;">
									<img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.jpg" : product.ImageUrl)" class="product-img" alt="@product.Title" />
								</div>
								<div class="p-4">
									@* BADGE BÁN CHẠY ĐƯỢC CHUYỂN XUỐNG DƯỚI, GỠ ICON TRÁI TIM *@
									<div class="d-flex align-items-center gap-2 mb-2">
										<span class="badge" style="background-color: #FFF8ED; color: #B8860B; border: 1px solid #F2E3C6; font-size: 0.6rem; letter-spacing: 0.05em; padding: 4px 8px;">
											<i class="bi bi-fire"></i> BÁN CHẠY
										</span>
										<span class="text-uppercase fw-bold text-truncate" style="font-size: 0.6rem; letter-spacing: 0.1em; color: var(--mfy-clay);">@product.Category?.Name</span>
									</div>

									<h5 class="fw-bold my-2 text-truncate" style="font-family: var(--serif);">@product.Title</h5>
									<div class="small text-muted mb-4"><i class="bi bi-person-circle"></i> Bởi @product.Seller?.User?.FullName</div>
									<div class="d-flex justify-content-between align-items-center pt-3 border-top">
										<span class="fw-bold fs-5" style="color: var(--mfy-bark);">@product.Price?.ToString("N0") đ</span>
										<a asp-page="/Products/Details" asp-route-id="@product.ProductId" class="btn btn-dark btn-sm rounded-pill px-4">Xem</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				}
			}
		</div>

		@* ========================================= *@
		@* ĐOẠN ĐẶT LÀM ĐỒ THEO YÊU CẦU *@
		@* ========================================= *@
		<section class="custom-section text-center shadow-lg">
			<div class="container position-relative" style="z-index: 2;">
				<span class="custom-tag">Dịch vụ thiết kế theo yêu cầu cao cấp</span>
				<h2 class="display-5 fw-bold mb-4" style="font-family: var(--serif); letter-spacing: -0.01em;">Bạn chưa tìm thấy sản phẩm mong muốn?</h2>
				<p class="opacity-75 mb-5 mx-auto fs-5" style="max-width: 700px;">Hãy kết nối trực tiếp cùng đội ngũ nghệ nhân xuất sắc của chúng tôi để tạo dựng nên tác phẩm độc bản mang đậm dấu ấn cá nhân. Toàn vẹn từ kích thước riêng biệt cho đến điêu khắc tên kỷ niệm.</p>
				<a href="/Products" class="btn btn-light rounded-pill px-5 py-3 fw-bold shadow">
					Khám phá nghệ nhân ngay <i class="bi bi-stars ms-2 text-warning"></i>
				</a>
			</div>
		</section>

		@* ========================================= *@
		@* SẢN PHẨM KHUYÊN DÙNG (EDITOR'S PICKS) *@
		@* ========================================= *@
		<div class="d-flex justify-content-between align-items-end mb-4">
			<div>
				<h2 style="font-family: var(--serif); font-weight: 700; font-size: 2.2rem;">Gợi ý từ Biên tập viên</h2>
				<p class="text-muted">Những tuyệt tác tinh tuyển được lựa chọn cẩn thận từ cộng đồng nghệ nhân.</p>
			</div>
			<a href="/Products" class="text-decoration-none fw-bold border-bottom border-2 pb-1" style="color: var(--mfy-clay);">Xem tất cả tác phẩm</a>
		</div>

		<div class="row g-4 mb-5">
			@if (Model.Products != null && Model.Products.Any())
			{
				@foreach (var product in Model.Products)
				{
					<div class="col-6 col-md-4 col-lg-3">
						@* BỌC CARD VÀO WRAPPER CHỐNG RUNG LẮC *@
						<div class="card-wrapper">
							<div class="product-card">
								<div style="overflow: hidden; position: relative;">
									<img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.jpg" : product.ImageUrl)" class="product-img" alt="@product.Title" />
									<div class="position-absolute top-0 end-0 p-3">
										<button class="btn btn-white btn-sm rounded-circle shadow-sm" style="width:35px; height:35px;"><i class="bi bi-heart text-danger"></i></button>
									</div>
								</div>
								<div class="p-4">
									<span class="text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.1em; color: var(--mfy-clay);">@product.Category?.Name</span>
									<h5 class="fw-bold my-2 text-truncate" style="font-family: var(--serif);">@product.Title</h5>
									<div class="small text-muted mb-4"><i class="bi bi-person-circle"></i> Bởi @product.Seller?.User?.FullName</div>
									<div class="d-flex justify-content-between align-items-center pt-3 border-top">
										<span class="fw-bold fs-5" style="color: var(--mfy-bark);">@product.Price?.ToString("N0") đ</span>
										<a asp-page="/Products/Details" asp-route-id="@product.ProductId" class="btn btn-dark btn-sm rounded-pill px-4">Xem</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				}
			}
		</div>
		@* ========================================= *@
		@* DANH MỤC HÀNG THỦ CÔNG *@
		@* ========================================= *@
		@if (Model.Categories != null && Model.Categories.Any())
		{
			<div class="d-flex justify-content-between align-items-end mb-4 pt-3">
				<div>
					<h2 style="font-family: var(--serif); font-weight: 700; font-size: 2.2rem;">Khám phá theo danh mục</h2>
					<p class="text-muted">Tìm kiếm tác phẩm theo từng loại hàng thủ công đặc sắc.</p>
				</div>
			</div>
			<div class="row g-3 mb-5">
				@{
					var catIcons = new[] { "bi-scissors", "bi-cup-hot", "bi-tree-fill", "bi-palette2", "bi-flower1" };
					var catColors = new[] { "#FFF4EC", "#EEF5FF", "#F0FAF0", "#FDF4FF", "#FFF0F5" };
					var catAccents = new[] { "#C8855A", "#4A7FCB", "#3A9B5A", "#9B5EC8", "#C85A8A" };
					int ci = 0;
				}
				@foreach (var cat in Model.Categories)
				{
					var icon = catIcons[ci % catIcons.Length];
					var bg = catColors[ci % catColors.Length];
					var accent = catAccents[ci % catAccents.Length];
					ci++;
					<div class="col-6 col-md-4 col-lg" style="min-width:160px;">
						<a href="/Products?categoryId=@cat.CategoryId" class="text-decoration-none d-block rounded-4 p-4 text-center category-card-link" style="background:@bg; border: 1px solid rgba(0,0,0,0.06); transition: 0.3s;">
							<div class="mb-2" style="font-size:2rem; color:@accent;">
								<i class="bi @icon"></i>
							</div>
							<div class="fw-bold" style="font-size:0.85rem; color:#2D2926; line-height:1.3;">@cat.Name</div>
						</a>
					</div>
				}
			</div>
			<style>
				.category-card-link:hover { transform: translateY(-6px); box-shadow: 0 12px 30px rgba(0,0,0,0.08); }
			</style>
		}

		@* ========================================= *@
		@* NGHỆ NHÂN NỔI BẬT *@
		@* ========================================= *@
		@if (Model.HomeData.FeaturedArtisans != null && Model.HomeData.FeaturedArtisans.Any())
		{
			<div class="d-flex justify-content-between align-items-end mb-4 pt-3">
				<div>
					<h2 style="font-family: var(--serif); font-weight: 700; font-size: 2.2rem;">Nghệ nhân nổi bật</h2>
					<p class="text-muted">Những nghệ nhân tài hoa được cộng đồng tin tưởng và yêu mến.</p>
				</div>
				<a href="/Products" class="text-decoration-none fw-bold border-bottom border-2 pb-1" style="color: var(--mfy-clay);">Xem tất cả</a>
			</div>
			<div class="row g-4 mb-5">
				@foreach (var artisan in Model.HomeData.FeaturedArtisans)
				{
					<div class="col-6 col-md-3">
						<a href="/Artisans/@artisan.SellerId" class="text-decoration-none artisan-card-link">
							<div class="text-center p-4 bg-white rounded-4 border" style="border-color: var(--mfy-border) !important; transition:0.3s;">
								@if (!string.IsNullOrEmpty(artisan.AvatarUrl))
								{
									<img src="@artisan.AvatarUrl" alt="@artisan.User?.FullName" class="rounded-circle mb-3 object-fit-cover" style="width:80px; height:80px;" />
								}
								else
								{
									<div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:80px; height:80px; background:var(--mfy-clay); color:white; font-size:1.5rem; font-family:var(--serif); font-weight:700;">
										@((artisan.ShopName ?? artisan.User?.FullName ?? "?").Substring(0, 1))
									</div>
								}
								<div class="fw-bold" style="font-family:var(--serif); font-size:1rem; color:#2D2926;">@(artisan.ShopName ?? artisan.User?.FullName)</div>
								<div class="small text-muted mt-1 mb-2">@artisan.User?.FullName</div>
								@if (artisan.AverageRating > 0)
								{
									<div class="small text-warning fw-bold"><i class="bi bi-star-fill me-1"></i>@artisan.AverageRating <span class="text-muted fw-normal">(@artisan.TotalReviews đánh giá)</span></div>
								}
							</div>
						</a>
					</div>
				}
			</div>
			<style>
				.artisan-card-link > div:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0,0,0,0.09); border-color: var(--mfy-clay) !important; }
			</style>
		}

		@* ========================================= *@
		@* THỐNG KÊ NỀN TẢNG *@
		@* ========================================= *@
		<div class="row g-4 mb-5 py-4" style="border-top: 1px solid var(--mfy-border); border-bottom: 1px solid var(--mfy-border);">
			<div class="col-6 col-md-3 text-center">
				<div style="font-family:var(--serif); font-size:2.5rem; font-weight:700; color:var(--mfy-clay);">500+</div>
				<div class="text-muted small mt-1">Tác phẩm thủ công</div>
			</div>
			<div class="col-6 col-md-3 text-center">
				<div style="font-family:var(--serif); font-size:2.5rem; font-weight:700; color:var(--mfy-clay);">50+</div>
				<div class="text-muted small mt-1">Nghệ nhân tài năng</div>
			</div>
			<div class="col-6 col-md-3 text-center">
				<div style="font-family:var(--serif); font-size:2.5rem; font-weight:700; color:var(--mfy-clay);">@Model.Categories.Count</div>
				<div class="text-muted small mt-1">Danh mục sản phẩm</div>
			</div>
			<div class="col-6 col-md-3 text-center">
				<div style="font-family:var(--serif); font-size:2.5rem; font-weight:700; color:var(--mfy-clay);">4.9★</div>
				<div class="text-muted small mt-1">Đánh giá trung bình</div>
			</div>
		</div>
	</div>
</body>