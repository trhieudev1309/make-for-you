@page
@model MakeForYou.Presentation.Pages.IndexModel
@{
	ViewData["Title"] = "MakeForYou – Sàn thương mại điện tử đồ thủ công";
}

<style>
	/* ── CẢI TIẾN THANH PHÂN LOẠI DANH MỤC (QUICK NAV) ── */
	.quick-nav-wrapper {
		border-top: 1px solid rgba(0, 0, 0, 0.05);
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
		background-color: #fbfbfb;
		width: 100%;
	}

	.quick-nav {
		display: flex;
		justify-content: center;
		gap: 3.5rem;
		padding: 1.1rem 0;
		overflow-x: auto;
		white-space: nowrap;
		scrollbar-width: none;
	}

		.quick-nav::-webkit-scrollbar {
			display: none;
		}

		.quick-nav a {
			font-family: 'Urbanist', var(--sans, sans-serif);
			font-size: 0.85rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			text-decoration: none;
			color: #333333;
			position: relative;
			padding: 0.25rem 0;
			transition: color 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		}

			.quick-nav a::after {
				content: "";
				position: absolute;
				bottom: 0;
				left: 0;
				width: 0;
				height: 2px;
				background-color: var(--mfy-clay, #C8855A);
				transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.quick-nav a:hover {
				color: var(--mfy-clay, #C8855A) !important;
			}

				.quick-nav a:hover::after {
					width: 100%;
				}

	/* ── HERO BANNER ── */
	.hero-banner {
		border-radius: 24px;
		overflow: hidden;
		height: 480px;
		position: relative;
		display: flex;
		align-items: center;
		padding: 5rem;
		color: white;
		background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.2)), url('https://images.unsplash.com/photo-1459411552884-841db9b3cc2a?auto=format&fit=crop&w=1400');
		background-size: cover;
		background-position: center;
		animation: fadeIn 1s ease;
	}

	.hero-content {
		max-width: 550px;
	}

		.hero-content h1 {
			font-family: var(--serif);
			font-size: 3.5rem;
			font-weight: 700;
			line-height: 1.15;
			margin-bottom: 1.5rem;
			text-shadow: 0 2px 10px rgba(0,0,0,0.2);
		}

	.btn-mfy-solid {
		background: var(--mfy-clay);
		color: white;
		padding: 1rem 2.5rem;
		border-radius: 50px;
		text-decoration: none;
		font-weight: 600;
		display: inline-block;
		transition: 0.3s;
		box-shadow: 0 4px 15px rgba(200, 133, 90, 0.3);
	}

		.btn-mfy-solid:hover {
			background: var(--mfy-clay-dark);
			transform: translateY(-3px);
			box-shadow: 0 6px 20px rgba(200, 133, 90, 0.4);
			color: white;
		}

	/* ── CUSTOMIZE SECTION ── */
	.custom-section {
		background: #1A1A1A;
		color: white;
		padding: 6rem 0;
		border-radius: 32px;
		margin: 5rem 0;
		position: relative;
		overflow: hidden;
	}

		.custom-section::after {
			content: "";
			position: absolute;
			top: 0;
			right: 0;
			width: 300px;
			height: 300px;
			background: radial-gradient(circle, rgba(200, 133, 90, 0.1) 0%, transparent 70%);
		}

	.custom-tag {
		font-family: var(--mono);
		color: var(--mfy-clay);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.4em;
		margin-bottom: 1.2rem;
		display: block;
	}

	/* ── PRODUCT CARDS (CẬP NHẬT KỸ THUẬT WRAPPER CHỐNG RUNG) ── */
	.card-wrapper {
		height: 100%;
		display: block;
	}

	.product-card {
		background: white;
		border: 1px solid var(--mfy-border);
		border-radius: 16px;
		overflow: hidden;
		height: 100%;
		transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	.card-wrapper:hover .product-card {
		transform: translateY(-12px);
		box-shadow: 0 25px 50px rgba(0,0,0,0.1);
		border-color: var(--mfy-clay);
	}

	.product-img {
		height: 280px;
		object-fit: cover;
		width: 100%;
		transition: 0.6s;
	}

	.card-wrapper:hover .product-img {
		transform: scale(1.05);
	}

	/* Responsive */
	@@media (max-width: 768px) {
		.hero-banner {
			height: auto;
			padding: 3rem 1.5rem;
			text-align: center;
		}

		.hero-content h1 {
			font-size: 2.5rem;
		}

		.quick-nav {
			gap: 1.8rem;
			justify-content: flex-start;
			padding: 1rem 1rem;
		}
	}
</style>
<body>

	@* THANH PHÂN LOẠI *@
	<div class="quick-nav-wrapper d-none d-md-block">
		<div class="container">
			<nav class="quick-nav">
				<a href="/Products?categoryId=1">Trang trí nhà cửa</a>
				<a href="/Products?categoryId=2">Trang sức</a>
				<a href="/Products?categoryId=3">Cổ điển</a>
				<a href="/Products?categoryId=4">Gốm sứ</a>
				<a href="/Products?categoryId=5">Tranh & Bản in</a>
				<a href="/Products?categoryId=6">Quà tặng</a>
			</nav>
		</div>
	</div>

	<div class="container mt-3">
		@* THANH TÌM KIẾM *@
		<style>
			.home-search-bar {
				padding: 4px;
				transition: all 0.3s ease;
			}
			.home-search-bar:focus-within {
				box-shadow: 0 6px 20px rgba(0,0,0,0.08) !important;
				border-color: rgba(200, 133, 90, 0.4) !important;
			}
			.home-search-input {
				font-family: 'Urbanist', var(--sans, sans-serif);
				font-size: 0.95rem;
				padding: 0.4rem 0.5rem;
			}
			.home-search-btn {
				background-color: var(--mfy-clay, #C8855A);
				color: white;
				font-weight: 600;
				font-size: 0.9rem;
				padding: 0.4rem 1.8rem;
				transition: all 0.3s ease;
			}
			.home-search-btn:hover {
				background-color: #b0724a;
				color: white;
			}
		</style>
		<div class="row justify-content-center mb-4">
			<div class="col-md-7 col-lg-6">
				<form action="/Products" method="get" class="d-flex bg-white rounded-pill shadow-sm border home-search-bar align-items-center">
					<i class="bi bi-search ms-4 text-muted" style="font-size: 1rem;"></i>
					<input type="text" name="searchTerm" class="form-control border-0 shadow-none bg-transparent home-search-input ms-2" placeholder="Tìm kiếm sản phẩm, người bán...">
					<button class="btn rounded-pill home-search-btn" type="submit">
						Tìm
					</button>
				</form>
			</div>
		</div>

		@* HERO BANNER *@
		<section class="hero-banner shadow-lg mb-5">
			<div class="hero-content">
				<h1>Nâng tầm không gian sống bằng cả tâm hồn.</h1>
				<p class="lead mb-5 opacity-90">Trải nghiệm vẻ đẹp tinh tế từ các sản phẩm thủ công. Mỗi tác phẩm là một minh chứng rõ nét cho sự sáng tạo và niềm đam mê sáng tạo của con người.</p>
				<a href="/Products" class="btn-mfy-solid">Khám phá ngay</a>
			</div>
		</section>

		@* ========================================= *@
		@* 🏆 SẢN PHẨM BÁN CHẠY NHẤT (BEST SELLERS) 🏆 *@
		@* ========================================= *@
		<div class="d-flex justify-content-between align-items-end mb-4 pt-3">
			<div>
				<h2 style="font-family: var(--serif); font-weight: 700; font-size: 2.2rem;">Sản phẩm bán chạy nhất</h2>
				<p class="text-muted">Những tuyệt tác thủ công được cộng đồng yêu thích và lựa chọn nhiều nhất.</p>
			</div>
			<a href="/Products" class="text-decoration-none fw-bold border-bottom border-2 pb-1" style="color: var(--mfy-clay);">Khám phá thêm</a>
		</div>

		<div class="row g-4 mb-5">
			@if (Model.BestSellers != null && Model.BestSellers.Any())
			{
				@foreach (var product in Model.BestSellers)
				{
					<div class="col-sm-6 col-md-4 col-lg-3">
						@* BỌC CARD VÀO WRAPPER CHỐNG RUNG LẮC *@
						<div class="card-wrapper">
							<div class="product-card">
								<div style="overflow: hidden; position: relative;">
									<img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.jpg" : product.ImageUrl)" class="product-img" alt="@product.Title" />
								</div>
								<div class="p-4">
									@* BADGE BÁN CHẠY ĐƯỢC CHUYỂN XUỐNG DƯỚI, GỠ ICON TRÁI TIM *@
									<div class="d-flex align-items-center gap-2 mb-2">
										<span class="badge" style="background-color: #FFF8ED; color: #B8860B; border: 1px solid #F2E3C6; font-size: 0.6rem; letter-spacing: 0.05em; padding: 4px 8px;">
											<i class="bi bi-fire"></i> BÁN CHẠY
										</span>
										<span class="text-uppercase fw-bold text-truncate" style="font-size: 0.6rem; letter-spacing: 0.1em; color: var(--mfy-clay);">@product.Category?.Name</span>
									</div>

									<h5 class="fw-bold my-2 text-truncate" style="font-family: var(--serif);">@product.Title</h5>
									<div class="small text-muted mb-4"><i class="bi bi-person-circle"></i> Bởi @product.Seller?.User?.FullName</div>
									<div class="d-flex justify-content-between align-items-center pt-3 border-top">
										<span class="fw-bold fs-5" style="color: var(--mfy-bark);">@product.Price?.ToString("N0") đ</span>
										<a asp-page="/Products/Details" asp-route-id="@product.ProductId" class="btn btn-dark btn-sm rounded-pill px-4">Xem</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				}
			}
		</div>

		@* ========================================= *@
		@* ĐOẠN ĐẶT LÀM ĐỒ THEO YÊU CẦU *@
		@* ========================================= *@
		<section class="custom-section text-center shadow-lg">
			<div class="container position-relative" style="z-index: 2;">
				<span class="custom-tag">Dịch vụ thiết kế theo yêu cầu cao cấp</span>
				<h2 class="display-5 fw-bold mb-4" style="font-family: var(--serif); letter-spacing: -0.01em;">Bạn chưa tìm thấy sản phẩm mong muốn?</h2>
				<p class="opacity-75 mb-5 mx-auto fs-5" style="max-width: 700px;">Hãy kết nối trực tiếp cùng đội ngũ nghệ nhân xuất sắc của chúng tôi để tạo dựng nên tác phẩm độc bản mang đậm dấu ấn cá nhân. Toàn vẹn từ kích thước riêng biệt cho đến điêu khắc tên kỷ niệm.</p>
				<a href="/CustomOrders/Create" class="btn btn-light rounded-pill px-5 py-3 fw-bold shadow">
					Bắt đầu thiết kế ngay <i class="bi bi-stars ms-2 text-warning"></i>
				</a>
			</div>
		</section>

		@* ========================================= *@
		@* SẢN PHẨM KHUYÊN DÙNG (EDITOR'S PICKS) *@
		@* ========================================= *@
		<div class="d-flex justify-content-between align-items-end mb-4">
			<div>
				<h2 style="font-family: var(--serif); font-weight: 700; font-size: 2.2rem;">Gợi ý từ Biên tập viên</h2>
				<p class="text-muted">Những tuyệt tác tinh tuyển được lựa chọn cẩn thận từ cộng đồng nghệ nhân.</p>
			</div>
			<a href="/Products" class="text-decoration-none fw-bold border-bottom border-2 pb-1" style="color: var(--mfy-clay);">Xem tất cả tác phẩm</a>
		</div>

		<div class="row g-4 mb-5">
			@if (Model.HomeData.FeaturedProducts != null && Model.HomeData.FeaturedProducts.Any())
			{
				@foreach (var product in Model.HomeData.FeaturedProducts)
				{
					<div class="col-sm-6 col-md-4 col-lg-3">
						@* BỌC CARD VÀO WRAPPER CHỐNG RUNG LẮC *@
						<div class="card-wrapper">
							<div class="product-card">
								<div style="overflow: hidden; position: relative;">
									<img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.jpg" : product.ImageUrl)" class="product-img" alt="@product.Title" />
									<div class="position-absolute top-0 end-0 p-3">
										<button class="btn btn-white btn-sm rounded-circle shadow-sm" style="width:35px; height:35px;"><i class="bi bi-heart text-danger"></i></button>
									</div>
								</div>
								<div class="p-4">
									<span class="text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.1em; color: var(--mfy-clay);">@product.Category?.Name</span>
									<h5 class="fw-bold my-2 text-truncate" style="font-family: var(--serif);">@product.Title</h5>
									<div class="small text-muted mb-4"><i class="bi bi-person-circle"></i> Bởi @product.Seller?.User?.FullName</div>
									<div class="d-flex justify-content-between align-items-center pt-3 border-top">
										<span class="fw-bold fs-5" style="color: var(--mfy-bark);">@product.Price?.ToString("N0") đ</span>
										<a asp-page="/Products/Details" asp-route-id="@product.ProductId" class="btn btn-dark btn-sm rounded-pill px-4">Xem</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				}
			}
		</div>
	</div>

	@* FOOTER *@
	<footer class="py-5" style="background: var(--mfy-bark); color: white; margin-top: 8rem;">
		<div class="container">
			<div class="row align-items-center">
				<div class="col-md-4 text-center text-md-start mb-4 mb-md-0">
					<a href="/" class="mfy-logo text-white" style="font-size: 2rem;">Make<span>For</span>You<div class="dot"></div></a>
				</div>
				<div class="col-md-4 text-center mb-4 mb-md-0">
					<div class="d-flex justify-content-center gap-4">
						<a href="/Products" class="text-white text-decoration-none opacity-75">Cửa hàng</a>
						<a href="/Artisans" class="text-white text-decoration-none opacity-75">Nghệ nhân</a>
						<a href="#" class="text-white text-decoration-none opacity-75">Giới thiệu</a>
					</div>
				</div>
				<div class="col-md-4 text-center text-md-end">
					<p class="small opacity-50 mb-0">Chế tác hoàn toàn thủ công từ trái tim &middot; 2026</p>
				</div>
			</div>
		</div>
	</footer>
</body>