@page
@using FUNews.Presentation.Constants
@model FUNews.Presentation.Pages.Admin.SystemAccounts.IndexModel

@{
    ViewData["Title"] = "Manage System Accounts";
}

<div class="container mt-4 animate-fade">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-semibold mb-1">System Accounts</h2>
            <p class="text-muted mb-0">
                Manage system users, roles, and access permissions.
            </p>
        </div>

        <button class="btn btn-primary"
                onclick="openCreateModal()">
            + New Account
        </button>
    </div>

    <!-- Search / Filter -->
    <div class="card border-0 shadow-sm mb-4 animate-fade" style="animation-delay: 0.1s;">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">

                <div class="col-md-4">
                    <label class="form-label small text-muted">Keyword</label>
                    <input type="text"
                           name="keyword"
                           value="@Model.Keyword"
                           class="form-control"
                           placeholder="Name, email, or role" />
                </div>

                <div class="col-md-3">
                    <label class="form-label small text-muted">Role</label>
                    <select name="role" class="form-select">
                        <option value="">All Roles</option>
                        <option value="@AccountRoles.Staff"
                                selected="@(Model.Role?.ToString() == AccountRoles.Staff.ToString())">
                            Staff
                        </option>
                        <option value="@AccountRoles.Lecturer"
                                selected="@(Model.Role?.ToString() == AccountRoles.Lecturer.ToString())">
                            Lecturer
                        </option>
                    </select>
                </div>

                <div class="col-md-3">
                    <button class="btn btn-primary me-2">Search</button>
                    <a class="btn btn-outline-secondary"
                       href="/Admin/SystemAccounts">
                        Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow animate-fade" style="animation-delay: 0.2s;">
        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var acc in Model.Accounts)
                    {
                        <tr class="table-row-animate">
                            <td class="fw-semibold">@acc.AccountName</td>
                            <td>@acc.AccountEmail</td>
                            <td>
                                <span class="badge bg-secondary">
                                    @AccountRoles.GetRoleByRoleId(acc.AccountRole ?? 0)
                                </span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-warning me-1"
                                        onclick="openEditModal(@acc.AccountId)">
                                    Edit
                                </button>

                                <button class="btn btn-sm btn-outline-secondary me-1"
                                        onclick="openChangePasswordModal(@acc.AccountId)">
                                    Password
                                </button>

                                <a class="btn btn-sm btn-outline-danger"
                                   asp-page-handler="Delete"
                                   asp-route-id="@acc.AccountId"
                                   onclick="return confirm('Are you sure you want to delete this account?');">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        // ================= EDIT =================

        function openEditModal(id) {
            $.get(`/Admin/SystemAccounts?handler=Edit&id=${id}`, function (html) {
                $('#modalContainer').html(html);
                $('#editAccountModal').modal('show');
            });
        }

        $(document).on('submit', '#editAccountForm', function (e) {
            e.preventDefault();

            $.ajax({
                url: '/Admin/SystemAccounts?handler=Edit',
                type: 'POST',
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        $('#modalContainer').html(res);
                        $('#editAccountModal').modal('show');
                    }
                }
            });
        });


        // ================= CHANGE PASSWORD =================

        function openChangePasswordModal(id) {
            $.get(`/Admin/SystemAccounts?handler=ChangePassword&id=${id}`, function (html) {
                $('#modalContainer').html(html);
                $('#changePasswordModal').modal('show');
            });
        }

        $(document).on('submit', '#changePasswordForm', function (e) {
            e.preventDefault();

            $.post('/Admin/SystemAccounts?handler=ChangePassword',
                $(this).serialize(),
                function (res) {
                    if (res.success) {
                        alert('Password changed successfully');
                        $('#changePasswordModal').modal('hide');
                    } else {
                        $('#passwordError').text(res.message);
                    }
                });
        });


        // ================= CREATE =================

        function openCreateModal() {
            $.get('/Admin/SystemAccounts?handler=Create', function (html) {
                $('#modalContainer').html(html);
                $('#createAccountModal').modal('show');
            });
        }

        $(document).on('submit', '#createAccountForm', function (e) {
            e.preventDefault();

            $.ajax({
                url: '/Admin/SystemAccounts?handler=Create',
                type: 'POST',
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        $('#createAccountBody').html(res);
                        $.validator.unobtrusive.parse('#createAccountForm');
                    }
                }
            });
        });

    </script>

    <partial name="_ValidationScriptsPartial" />
}
