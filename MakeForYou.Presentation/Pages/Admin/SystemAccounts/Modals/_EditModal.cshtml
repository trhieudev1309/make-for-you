@using FUNews.Presentation.Constants
@model FUNews.BusinessLogic.Entities.SystemAccount

<div class="modal fade" id="editAccountModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit System Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="editAccountForm">
                <div class="modal-body">

                    <input type="hidden" asp-for="AccountId" />
                    <input type="hidden" asp-for="AccountPassword" />

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label>Name</label>
                        <input asp-for="AccountName" class="form-control" />
                        <span asp-validation-for="AccountName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label>Email</label>
                        <input asp-for="AccountEmail" class="form-control" />
                        <span asp-validation-for="AccountEmail" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label>Role</label>
                        <select asp-for="AccountRole" class="form-select">
                            <option value="@AccountRoles.Lecturer">Lecturer</option>
                            <option value="@AccountRoles.Staff">Staff</option>
                        </select>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
