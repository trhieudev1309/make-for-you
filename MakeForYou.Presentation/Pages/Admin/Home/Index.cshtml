@page
@model FUNews.Presentation.Pages.Admin.Home.IndexModel
@{
	ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4 animate-fade">

	<!-- Header -->
	<div class="mb-5">
		<h2 class="fw-semibold mb-1">Admin Dashboard</h2>
		<p class="text-muted">
			Manage system data, monitor activity, and access administrative tools.
		</p>
	</div>

	<div class="row g-4">

		<!-- Account Management -->
		<div class="col-md-4 animate-fade" style="animation-delay: 0.1s;">
			<div class="card border-0 shadow dashboard-tile h-100">
				<div class="card-body p-4">

					<div class="mb-3 text-primary fs-3">
						👤
					</div>

					<h5 class="fw-semibold mb-2">Account Management</h5>
					<p class="text-muted small mb-4">
						Create, update, search, and manage system user accounts and roles.
					</p>

					<a asp-page="/Admin/SystemAccounts/Index"
					   class="btn btn-primary btn-sm">
						Manage Accounts
					</a>
				</div>
			</div>
		</div>

		<!-- Reporting & Statistics -->
		<div class="col-md-4 animate-fade" style="animation-delay: 0.25s;">
			<div class="card border-0 shadow dashboard-tile h-100">
				<div class="card-body p-4">

					<div class="mb-3 text-success fs-3">
						📊
					</div>

					<h5 class="fw-semibold mb-2">Reporting & Statistics</h5>
					<p class="text-muted small mb-4">
						Analyze articles by category, author, status, and publication period.
					</p>

					<a asp-page="/Admin/Reports/Index"
					   class="btn btn-primary btn-sm">
						View Reports
					</a>
				</div>
			</div>
		</div>

		<!-- Change Audit -->
		<div class="col-md-4 animate-fade" style="animation-delay: 0.4s;">
			<div class="card border-0 shadow dashboard-tile h-100">
				<div class="card-body p-4">

					<div class="mb-3 text-warning fs-3">
						🕒
					</div>

					<h5 class="fw-semibold mb-2">Change Audit</h5>
					<p class="text-muted small mb-4">
						Track editor actions, modifications, and latest updates on articles.
					</p>

					<a asp-page="/Admin/Audit/Index"
					   class="btn btn-warning btn-sm text-white">
						View Audit
					</a>
				</div>
			</div>
		</div>

	</div>
</div>
