@page
@using MakeForYou.BusinessLogic.Entities.Enums
@model MakeForYou.Presentation.Pages.Admin.UsersModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý người dùng";
    ViewData["ActivePage"] = "Users";
}

@* TIÊU ĐỀ VÀ NÚT THÊM MỚI *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="serif-heading fw-bold mb-0">Quản lý người dùng</h2>
        <p class="text-muted small mb-0">Cấp quyền, khóa hoặc mở khóa tài khoản người dùng hệ thống.</p>
    </div>
    <button type="button" class="btn btn-dark rounded-pill px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#addUserModal">
        <i class="bi bi-person-plus me-2"></i> Thêm thành viên
    </button>
</div>

@* 1. THANH TÌM KIẾM VÀ BỘ LỌC (Tự động lọc khi chọn) *@
<div class="card border-0 shadow-sm p-3 mb-4 bg-white">
    <form method="get" id="filterForm" class="row g-2">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                <input asp-for="SearchTerm" 
                       class="form-control border-0 bg-light shadow-none" 
                       placeholder="Tìm theo tên hoặc email và nhấn Enter..." />
            </div>
        </div>

        <div class="col-md-3">
            <select asp-for="RoleFilter" 
                    class="form-select border-0 bg-light shadow-none" 
                    onchange="this.form.submit()">
                <option value="">Tất cả Vai trò</option>
                <option value="0">Buyer (Người mua)</option>
                <option value="1">Seller (Nghệ nhân)</option>
                <option value="2">Admin (Quản trị)</option>
            </select>
        </div>

        <div class="col-md-3">
            <select asp-for="StatusFilter" 
                    class="form-select border-0 bg-light shadow-none" 
                    onchange="this.form.submit()">
                <option value="">Tất cả Trạng thái</option>
                <option value="0">Hoạt động</option>
                <option value="1">Chưa kích hoạt</option>
                <option value="2">Đã khóa</option>
            </select>
        </div>
    </form>
</div>

<div class="card border-0 shadow-sm overflow-hidden text-center text-md-start">
    <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
            <tr class="small-caps" style="font-size: 0.75rem;">
                <th class="ps-4">NGƯỜI DÙNG</th>
                <th>VAI TRÒ</th>
                <th>TRẠNG THÁI</th>
                <th class="text-end pe-4">THAO TÁC</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.UserList) {
                <tr>
                    <td class="ps-4">
                        <div class="d-flex align-items-center">
                            <div class="avatar-circle me-3">@user.FullName[0]</div>
                            <div>
                                <div class="fw-bold text-dark">@user.FullName</div>
                                <div class="text-muted small">@user.Email</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge bg-light text-dark border fw-normal px-3 rounded-pill">@((UserRole)user.Role)</span>
                    </td>
                    <td>
                        @if (user.Status == (int)UserStatus.Active) {
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 rounded-pill">Hoạt động</span>
                        } else if (user.Status == (int)UserStatus.Banned) {
                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 rounded-pill">Đã khóa</span>
                        } else {
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 rounded-pill">Chưa kích hoạt</span>
                        }
                    </td>
                    <td class="text-end pe-4">
                        <div class="btn-group shadow-sm rounded-pill bg-white overflow-hidden">
                            @* Nút mở Modal sửa thông tin tổng hợp *@
                            <button onclick="openEditUserModal(@user.UserId, @user.Role, '@user.FullName', '@user.Phone')" class="btn btn-sm btn-white border-end text-primary" title="Chỉnh sửa">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            @* Nút Khóa/Mở trạng thái *@
                            <form method="post" asp-page-handler="UpdateStatus" style="display:inline;">
                                <input type="hidden" name="id" value="@user.UserId" />
                                <input type="hidden" name="status" value="@(user.Status == 0 ? 2 : 0)" />
                                <button type="submit" class="btn btn-sm btn-white @(user.Status == 0 ? "text-danger" : "text-success")" title="@(user.Status == 0 ? "Khóa tài khoản" : "Mở khóa tài khoản")">
                                    <i class="bi @(user.Status == 0 ? "bi-lock" : "bi-unlock")"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <div class="d-flex justify-content-center py-4 bg-light border-top">
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= Model.TotalPages; i++) {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link shadow-none" asp-route-CurrentPage="@i" 
                               asp-route-SearchTerm="@Model.SearchTerm" 
                               asp-route-RoleFilter="@Model.RoleFilter"
                               asp-route-StatusFilter="@Model.StatusFilter">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

@* --- MODAL CHỈNH SỬA THÔNG TIN (Họ tên, SĐT, Vai trò) --- *@
<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg">
            <form method="post" asp-page-handler="UpdateUser">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Chỉnh sửa người dùng</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-3">
                    <input type="hidden" name="id" id="editUserId" />
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">HỌ VÀ TÊN</label>
                        <input name="fullName" id="editFullName" class="form-control border-0 bg-light shadow-none" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">SỐ ĐIỆN THOẠI</label>
                        <input name="phone" id="editPhone" class="form-control border-0 bg-light shadow-none" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label small fw-bold text-muted">VAI TRÒ</label>
                        <select name="newRole" id="editRoleSelect" class="form-select border-0 bg-light shadow-none">
                            <option value="0">Buyer (Người mua)</option>
                            <option value="1">Seller (Nghệ nhân)</option>
                            <option value="2">Admin (Quản trị)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light btn-sm rounded-pill px-3" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-clay btn-sm rounded-pill px-4 text-white shadow-sm fw-bold">
                        Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* --- MODAL THÊM THÀNH VIÊN MỚI --- *@
<div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form method="post" asp-page-handler="AddUser">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold serif-heading">Tạo tài khoản mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">HỌ VÀ TÊN</label>
                        <input asp-for="NewUser.FullName" class="form-control border-0 bg-light shadow-none" placeholder="Nhập tên người dùng..." required />
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">EMAIL</label>
                            <input asp-for="NewUser.Email" type="email" class="form-control border-0 bg-light shadow-none" placeholder="email@vi-du.com" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">SỐ ĐIỆN THOẠI</label>
                            <input asp-for="NewUser.Phone" type="tel" class="form-control border-0 bg-light shadow-none" placeholder="09xx..." />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">MẬT KHẨU</label>
                            <input asp-for="NewUserPassword" type="password" class="form-control border-0 bg-light shadow-none" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">VAI TRÒ</label>
                            <select asp-for="NewUser.Role" class="form-select border-0 bg-light shadow-none">
                                <option value="0">Buyer (Người mua)</option>
                                <option value="1">Seller (Nghệ nhân)</option>
                                <option value="2">Admin (Quản trị)</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-dark rounded-pill px-4 shadow-sm">Tạo người dùng</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .avatar-circle {
        width: 38px; height: 38px; background: var(--mfy-clay, #C8855A); color: white;
        display: flex; align-items: center; justify-content: center;
        border-radius: 50%; font-weight: bold;
    }
    .bg-success-subtle { background-color: #e8f5e9; }
    .bg-danger-subtle { background-color: #ffebee; }
    .bg-secondary-subtle { background-color: #f5f5f5; }
    .text-clay { color: #C8855A; }
    .btn-clay { background-color: #C8855A; border: none; }
    .btn-clay:hover { background-color: #b0724a; color: white; }
    .btn-white { background: white; border: none; transition: 0.2s; }
    .btn-white:hover { background: #f8f9fa; }
    .small-caps { font-weight: 700; letter-spacing: 0.05em; color: #6c757d; }
    .serif-heading { font-family: 'Playfair Display', serif; }
</style>

@section Scripts {
    <script>
        function openEditUserModal(id, role, name, phone) {
            document.getElementById('editUserId').value = id;
            document.getElementById('editFullName').value = name;
            // Xử lý trường hợp phone bị null từ DB
            document.getElementById('editPhone').value = (phone === 'null' || phone === null) ? '' : phone;
            document.getElementById('editRoleSelect').value = role;
            
            var myModal = new bootstrap.Modal(document.getElementById('editUserModal'));
            myModal.show();
        }
    </script>
}