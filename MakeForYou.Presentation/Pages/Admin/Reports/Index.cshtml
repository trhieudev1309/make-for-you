@page
@model FUNews.Presentation.Pages.Admin.Reports.IndexModel

@{
    ViewData["Title"] = "Reporting & Statistics";
    var categories = Model.ByCategory;
    var authors = Model.ByAuthor;
}

<div class="container mt-4 animate-fade">

    <!-- Header -->
    <div class="mb-4">
        <h2 class="fw-semibold mb-1">Reporting & Statistics</h2>
        <p class="text-muted mb-0">
            Analyze article activity and performance over a selected period.
        </p>
    </div>

    <!-- Filter -->
    <div class="card border-0 shadow-sm mb-4 animate-fade" style="animation-delay: 0.1s;">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small text-muted">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label small text-muted">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                </div>

                <div class="col-md-3">
                    <button class="btn btn-primary">
                        Generate Report
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Status Summary -->
    <div class="row mb-4">

        <div class="col-md-6 animate-fade" style="animation-delay: 0.2s;">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted mb-3">Status Summary</h6>

                    <div class="d-flex justify-content-between mb-2">
                        <span>Active Articles</span>
                        <span class="badge bg-success fs-6">
                            @Model.ActiveCount
                        </span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Inactive Articles</span>
                        <span class="badge bg-secondary fs-6">
                            @Model.ActiveCount
                        </span>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Charts Row -->
    <div class="row g-4">

        <!-- Category Chart -->
        <div class="col-md-6 animate-fade" style="animation-delay: 0.3s;">
            <div class="card border-0 shadow h-100">
                <div class="card-body">
                    <h6 class="text-muted mb-3">Articles by Category</h6>
                    <canvas id="categoryChart" height="220"></canvas>
                </div>
            </div>
        </div>

        <!-- Author Chart -->
        <div class="col-md-6 animate-fade" style="animation-delay: 0.4s;">
            <div class="card border-0 shadow h-100">
                <div class="card-body">
                    <h6 class="text-muted mb-3">Articles by Author</h6>
                    <canvas id="authorChart" height="220"></canvas>
                </div>
            </div>
        </div>

    </div>

</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const categoryLabels = @Html.Raw(
                            System.Text.Json.JsonSerializer.Serialize(categories.Keys.ToList())
                    );
        const categoryData = @Html.Raw(
                        System.Text.Json.JsonSerializer.Serialize(categories.Values.ToList())
                );

        const authorLabels = @Html.Raw(
                        System.Text.Json.JsonSerializer.Serialize(authors.Keys.ToList())
                );
        const authorData = @Html.Raw(
                        System.Text.Json.JsonSerializer.Serialize(authors.Values.ToList())
                );

        // Category Chart
        new Chart(document.getElementById('categoryChart'), {
            type: 'bar',
            data: {
                labels: categoryLabels,
                datasets: [{
                    data: categoryData,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                animation: {
                    duration: 900,
                    easing: 'easeOutQuart'
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });

            // Author Chart (Horizontal)
            new Chart(document.getElementById('authorChart'), {
                type: 'bar',
                data: {
                    labels: authorLabels,
                    datasets: [{
                        data: authorData,
                        borderRadius: 6
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    plugins: {
                        legend: { display: false }
                    },
                    animation: {
                        duration: 900,
                        easing: 'easeOutQuart'
                    },
                    scales: {
                        x: { beginAtZero: true }
                    }
                }
            });
        });
    </script>
}

