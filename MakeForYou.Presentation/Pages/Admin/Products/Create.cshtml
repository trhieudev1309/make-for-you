@page
@model MakeForYou.Presentation.Pages.Admin.Products.CreateModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm sản phẩm mới";
    ViewData["ActivePage"] = "Products";
}

<div class="card p-4 shadow-sm border-0">
    <div class="mb-4">
        <h2 class="serif-heading fw-bold" style="color: var(--mfy-bark)">Thêm sản phẩm nghệ thuật</h2>
        <p class="text-muted">Admin có thể gán sản phẩm này cho một nghệ nhân cụ thể trong hệ thống.</p>
    </div>

    <form method="post">
        <div class="row">
            <div class="col-md-12 mb-3">
                <label class="form-label fw-bold">Tên sản phẩm</label>
                <input asp-for="Product.Title" class="form-control shadow-sm" placeholder="VD: Alpaca Infinity Scarf" required />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Nghệ nhân sở hữu (Seller)</label>
                <select asp-for="Product.SellerId" class="form-select shadow-sm" required>
                    <option value="">-- Chọn nghệ nhân --</option>
                    @foreach (var seller in Model.Sellers)
                    {
                        @* Hiển thị ID và Bio ngắn để Admin phân biệt *@
                        <option value="@seller.SellerId">ID: @seller.SellerId - @(seller.Bio?.Length > 30 ? seller.Bio.Substring(0, 30) + "..." : seller.Bio)</option>
                    }
                </select>
                <span asp-validation-for="Product.SellerId" class="text-danger small"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Danh mục sản phẩm</label>
                <select asp-for="Product.CategoryId" class="form-select shadow-sm" required>
                    <option value="">-- Chọn danh mục --</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.CategoryId">@cat.Name</option>
                    }
                </select>
                <span asp-validation-for="Product.CategoryId" class="text-danger small"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                <div class="input-group">
                    <input asp-for="Product.Price" type="number" class="form-control shadow-sm" required />
                    <span class="input-group-text">VNĐ</span>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Link ảnh đại diện (URL)</label>
                <input asp-for="Product.ImageUrl" class="form-control shadow-sm" placeholder="https://..." />
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">Mô tả chi tiết</label>
            <textarea asp-for="Product.Description" class="form-control shadow-sm" rows="4" placeholder="Viết vài dòng giới thiệu về sản phẩm này..."></textarea>
        </div>

        <!-- NEW: CUSTOMIZATION SECTION -->
        <div class="mb-4 border-top pt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="serif-heading fw-bold" style="color: var(--mfy-bark)">Tùy chỉnh nhanh (Optional)</h5>
                <button type="button" class="btn btn-sm btn-outline-clay" id="addCustomizationGroupBtn">
                    <i class="bi bi-plus-lg me-1"></i>Thêm nhóm tùy chỉnh
                </button>
            </div>
            <p class="text-muted small mb-3">Thêm các lựa chọn tùy chỉnh như Kích thước, Chất liệu, v.v.</p>

            <div id="customizationGroupsContainer">
                <!-- Customization groups will be added here dynamically -->
            </div>

            <!-- Hidden input to store customizations as JSON -->
            <input type="hidden" id="customizationsJson" name="CustomizationsJson" value="" />
        </div>

        <div class="d-flex justify-content-end gap-2 border-top pt-4">
            <a href="/Admin/Products" class="btn btn-light rounded-pill px-4">Hủy bỏ</a>
            <button type="submit" class="btn btn-clay rounded-pill px-5 shadow-sm">
                <i class="bi bi-check-lg me-2"></i>Lưu sản phẩm
            </button>
        </div>
    </form>
</div>

<style>
    .btn-clay { background-color: var(--mfy-clay); color: white; border: none; }
    .btn-clay:hover { background-color: #b0724a; color: white; }
    .btn-outline-clay { color: var(--mfy-clay); border-color: var(--mfy-clay); }
    .btn-outline-clay:hover { background-color: var(--mfy-clay); color: white; }
    .form-control:focus, .form-select:focus { border-color: var(--mfy-clay); box-shadow: 0 0 0 0.25rem rgba(200, 133, 90, 0.25); }
    
    .customization-group {
        background: #f8f7f5;
        border: 1px solid #e8e3dd;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 16px;
        position: relative;
    }

    .customization-options-list {
        background: white;
        border: 1px solid #e8e3dd;
        border-radius: 6px;
        padding: 12px;
        max-height: 250px;
        overflow-y: auto;
        margin-bottom: 12px;
    }

    .customization-option-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px;
        background: #f8f7f5;
        border-radius: 4px;
        margin-bottom: 8px;
    }

    .customization-option-item:last-child {
        margin-bottom: 0;
    }

    .remove-option-btn, .remove-group-btn {
        background: none;
        border: none;
        color: #d32f2f;
        cursor: pointer;
        padding: 4px 8px;
    }

    .remove-option-btn:hover, .remove-group-btn:hover {
        opacity: 0.7;
    }
</style>

<script>
    let groupCounter = 0;
    let optionCounter = {};

    document.addEventListener('DOMContentLoaded', function () {
        const addGroupBtn = document.getElementById('addCustomizationGroupBtn');
        addGroupBtn.addEventListener('click', function (e) {
            e.preventDefault();
            addCustomizationGroup();
        });

        // Initialize delete handlers
        updateDeleteHandlers();
    });

    function addCustomizationGroup() {
        const container = document.getElementById('customizationGroupsContainer');
        const groupId = groupCounter++;
        optionCounter[groupId] = 0;

        const groupHtml = `
            <div class="customization-group" data-group-id="${groupId}">
                <button type="button" class="remove-group-btn" style="float: right;">
                    <i class="bi bi-trash3"></i>
                </button>
                
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tiêu đề nhóm tùy chỉnh</label>
                        <input type="text" class="form-control shadow-sm group-title" placeholder="VD: Kích thước, Chất liệu" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Thứ tự hiển thị</label>
                        <input type="number" class="form-control shadow-sm group-display-order" value="0" min="0" />
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label fw-bold mb-0">Các tùy chọn</label>
                        <button type="button" class="btn btn-sm btn-outline-secondary add-option-btn">
                            <i class="bi bi-plus-lg me-1"></i>Thêm lựa chọn
                        </button>
                    </div>
                    <div class="customization-options-list" data-group-id="${groupId}">
                        <!-- Options will be added here -->
                    </div>
                </div>
            </div>
        `;

        container.insertAdjacentHTML('beforeend', groupHtml);
        updateDeleteHandlers();

        // Add option handler
        const addOptionBtn = container.querySelector(`[data-group-id="${groupId}"] .add-option-btn`);
        addOptionBtn.addEventListener('click', function (e) {
            e.preventDefault();
            addCustomizationOption(groupId);
        });
    }

    function addCustomizationOption(groupId) {
        const optionList = document.querySelector(`.customization-options-list[data-group-id="${groupId}"]`);
        const optionId = optionCounter[groupId]++;

        const optionHtml = `
            <div class="customization-option-item" data-option-id="${optionId}">
                <input type="text" class="form-control form-control-sm option-value" placeholder="VD: S, M, L, XL" required style="flex: 1;" />
                <input type="number" class="form-control form-control-sm option-display-order" value="0" min="0" style="width: 80px;" />
                <button type="button" class="remove-option-btn" title="Xóa">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        `;

        optionList.insertAdjacentHTML('beforeend', optionHtml);
        updateDeleteHandlers();
    }

    function updateDeleteHandlers() {
        // Delete group handlers
        document.querySelectorAll('.remove-group-btn').forEach(btn => {
            btn.onclick = function (e) {
                e.preventDefault();
                const group = this.closest('.customization-group');
                group.remove();
                serializeCustomizations();
            };
        });

        // Delete option handlers
        document.querySelectorAll('.remove-option-btn').forEach(btn => {
            btn.onclick = function (e) {
                e.preventDefault();
                const option = this.closest('.customization-option-item');
                option.remove();
                serializeCustomizations();
            };
        });
    }

    function serializeCustomizations() {
        const customizations = [];

        document.querySelectorAll('.customization-group').forEach((group, groupIndex) => {
            const title = group.querySelector('.group-title').value;
            const displayOrder = parseInt(group.querySelector('.group-display-order').value) || 0;

            const options = [];
            group.querySelectorAll('.customization-option-item').forEach((item, optionIndex) => {
                const optionValue = item.querySelector('.option-value').value;
                const optionOrder = parseInt(item.querySelector('.option-display-order').value) || 0;

                if (optionValue.trim()) {
                    options.push({
                        optionValue: optionValue,
                        displayOrder: optionOrder
                    });
                }
            });

            if (title.trim() && options.length > 0) {
                customizations.push({
                    title: title,
                    displayOrder: displayOrder,
                    options: options
                });
            }
        });

        // Store as JSON in hidden input
        document.getElementById('customizationsJson').value = JSON.stringify(customizations);
    }

    // Serialize customizations before form submission
    document.querySelector('form').addEventListener('submit', function () {
        serializeCustomizations();
    });

    // Also serialize when changes are made
    document.addEventListener('change', function (e) {
        if (e.target.classList.contains('group-title') ||
            e.target.classList.contains('group-display-order') ||
            e.target.classList.contains('option-value') ||
            e.target.classList.contains('option-display-order')) {
            serializeCustomizations();
        }
    });
</script>