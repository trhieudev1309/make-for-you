@page
@model FUNews.Presentation.Pages.Admin.Audit.IndexModel

@using FUNews.BusinessLogic.Entities

@{
	ViewData["Title"] = "Change Audit";
}

<style>
	.fade-in {
		animation: fadeInUp 0.6s ease-out both;
	}

	.audit-card {
		border-radius: 12px;
		box-shadow: 0 8px 24px rgba(0,0,0,.05);
	}

	.table-hover tbody tr {
		transition: background-color .2s ease;
	}

	.badge-status {
		font-size: .85rem;
		padding: .45em .7em;
		border-radius: 999px;
	}
</style>

<div class="container mt-4 fade-in">

	<div class="card audit-card">
		<div class="card-body">

			<div class="d-flex justify-content-between align-items-center mb-3">
				<div>
					<h3 class="mb-1">Change Audit</h3>
					<small class="text-muted">
						Shows the latest modification information for each article.
					</small>
				</div>
			</div>

			<div class="table-responsive">
				<table class="table table-hover align-middle">
					<thead class="table-light">
						<tr>
							<th>Title</th>
							<th>Created By</th>
							<th>Created Date</th>
							<th>Last Edited By</th>
							<th>Last Modified</th>
							<th>Status</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var a in Model.Articles)
						{
							<tr>
								<td>
									<div class="fw-semibold">@a.NewsTitle</div>
								</td>

								<td>@a.CreatedBy?.AccountName</td>

								<td>
									@a.CreatedDate?.ToString("dd/MM/yyyy HH:mm")
								</td>

								<td>
									@(a.UpdatedById != null
																	? Model.Accounts
																	.FirstOrDefault(x => x.AccountId == a.UpdatedById)
																	?.AccountName
																	: "—")
										  							</td>

								<td>
									@(a.ModifiedDate != null
																	? a.ModifiedDate.Value.ToString("dd/MM/yyyy HH:mm")
																	: "—")
							</td>

								<td>
								@if (a.NewsStatus == true)
									{
										<span class="badge bg-success badge-status">Active</span>
									}
									else
									{
										<span class="badge bg-secondary badge-status">Inactive</span>
									}
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>

		</div>
	</div>

</div>
