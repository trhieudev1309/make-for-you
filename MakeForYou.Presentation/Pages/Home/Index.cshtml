@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="row justify-content-center mt-5 animate-fade">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5 text-center">

                <h1 class="display-6 fw-semibold mb-3">
                    FUNews Management System
                </h1>

                <p class="lead text-muted mb-4">
                    A centralized platform for managing, reviewing, and publishing news content efficiently.
                </p>

                <div class="row mt-4 mb-4">
                    <div class="col-md-4 animate-fade" style="animation-delay: 0.1s;">
                        <h6 class="fw-semibold">Role-based Access</h6>
                        <p class="text-muted small">
                            Admin, Staff, and Lecturer dashboards with clear permissions.
                        </p>
                    </div>

                    <div class="col-md-4 animate-fade" style="animation-delay: 0.25s;">
                        <h6 class="fw-semibold">Content Control</h6>
                        <p class="text-muted small">
                            Create, edit, approve, and manage articles in one place.
                        </p>
                    </div>

                    <div class="col-md-4 animate-fade" style="animation-delay: 0.4s;">
                        <h6 class="fw-semibold">Organized Structure</h6>
                        <p class="text-muted small">
                            Categories, tags, and status tracking for every article.
                        </p>
                    </div>
                </div>

                <p class="text-muted mb-4 animate-fade" style="animation-delay: 0.55s;">
                    Please log in to access the system.
                </p>

                <a asp-page="/Auth/Register"
                   class="btn btn-primary btn-lg px-5 animate-fade"
                   style="animation-delay: 0.7s;">
                    Register
                </a>

            </div>
        </div>
    </div>
</div>
