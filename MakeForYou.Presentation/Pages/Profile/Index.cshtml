@page
@model MakeForYou.Presentation.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "Hồ Sơ Của Tôi";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">

<div class="serif-scope">
  <div class="serif-container">
    <nav aria-label="Breadcrumb" class="mb-3">
      <ol class="breadcrumb small-caps" style="background:transparent;padding:0;margin:0;display:flex;gap:.5rem;">
        <li class="breadcrumb-item"><a asp-page="/Home/Index" class="text-decoration-none text-reset small-caps">Trang Chủ</a></li>
        <li class="breadcrumb-item text-muted small-caps" aria-current="page">Hồ Sơ</li>
      </ol>
    </nav>

    <header class="mb-5">
      <div class="small-caps">Tài Khoản</div>
      <h1 class="serif-title">Hồ Sơ Của Tôi</h1>
      <p class="text-muted-serif">Quản lý thông tin tài khoản và tùy chọn của bạn</p>
    </header>

    @if (Model.UserProfile != null)
    {
      <div class="row gy-4">
        <!-- Left: Profile Info -->
        <div class="col-lg-7">
          <div class="meta-card">
            <div class="small-caps mb-3">Thông Tin Cá Nhân</div>

            <dl class="row mb-3">
              <dt class="col-sm-4 small-caps">Họ và Tên</dt>
              <dd class="col-sm-8">@Model.UserProfile.FullName</dd>

              <dt class="col-sm-4 small-caps">Email</dt>
              <dd class="col-sm-8">@Model.UserProfile.Email</dd>

              <dt class="col-sm-4 small-caps">Số điện thoại</dt>
              <dd class="col-sm-8">
                @if (!string.IsNullOrEmpty(Model.UserProfile.Phone))
                {
                  @Model.UserProfile.Phone
                }
                else
                {
                  <span class="text-muted-serif">Chưa cung cấp</span>
                }
              </dd>

              <dt class="col-sm-4 small-caps">Thành viên từ</dt>
              <dd class="col-sm-8">@Model.UserProfile.CreatedAt.ToLocalTime().ToString("MMMM d, yyyy")</dd>
            </dl>

            <hr style="border-color:var(--serif-border);" />

            <div class="d-grid gap-2 mt-3">
              <a asp-page="/Profile/Edit" class="btn btn-primary serif">Chỉnh Sửa Hồ Sơ</a>
              <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#changePasswordModal">Đổi Mật Khẩu</button>
            </div>
          </div>

          <!-- Account Status Card -->
          <div class="meta-card mt-3">
            <div class="small-caps mb-2">Trạng Thái Tài Khoản</div>
            <div class="d-flex align-items-center gap-2">
              <span style="display:inline-block;width:10px;height:10px;background:var(--serif-accent);border-radius:50%;"></span>
              <span class="serif-body">Tài khoản đang hoạt động</span>
            </div>
          </div>
        </div>

        <!-- Right: Avatar / Quick Stats -->
        <aside class="col-lg-5">
          <div class="about-card">
            <div class="d-flex flex-column align-items-center text-center gap-3">
              <div class="profile-avatar" style="width:120px;height:120px;font-size:2.5rem;">
                @if (!string.IsNullOrEmpty(Model.UserProfile.FullName))
                {
                  @Model.UserProfile.FullName.Substring(0,1).ToUpper()
                }
              </div>
              <div>
                <h2 class="serif-title" style="font-size:1.35rem;margin:0;">@Model.UserProfile.FullName</h2>
                <p class="text-muted-serif">@Model.UserProfile.Email</p>
              </div>
            </div>
          </div>

          <!-- Role Badge -->
          @if (Model.UserProfile.Seller != null)
          {
            <div class="about-card mt-3">
              <div class="small-caps mb-2">Người Bán</div>
              <p class="serif-body text-muted-serif">Bạn có quyền người bán</p>
              <a asp-page="/Sellers/Dashboard" class="btn btn-sm btn-outline-dark w-100">Xem Bảng Điều Khiển Người Bán</a>
            </div>
          }

          @if (Model.UserProfile.Buyer != null)
          {
            <div class="about-card mt-3">
              <div class="small-caps mb-2">Người Mua</div>
              <p class="serif-body text-muted-serif">Bạn có quyền người mua</p>
              <a href="/Orders" class="btn btn-sm btn-outline-dark w-100">Xem Đơn Hàng Của Tôi</a>
            </div>
          }
        </aside>
      </div>
    }
  </div>
</div>

<!-- Change Password Modal -->
<div class="modal fade" id="changePasswordModal" tabindex="-1" aria-labelledby="changePasswordLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title serif-title" id="changePasswordLabel">Đổi Mật Khẩu</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="post" asp-page="/Profile/ChangePassword">
        <div class="modal-body">
          <div class="mb-3">
            <label for="currentPassword" class="form-label small-caps">Mật khẩu hiện tại</label>
            <input type="password" class="form-control" id="currentPassword" name="CurrentPassword" required />
          </div>
          <div class="mb-3">
            <label for="newPassword" class="form-label small-caps">Mật khẩu mới</label>
            <input type="password" class="form-control" id="newPassword" name="NewPassword" required />
          </div>
          <div class="mb-3">
            <label for="confirmPassword" class="form-label small-caps">Xác nhận mật khẩu</label>
            <input type="password" class="form-control" id="confirmPassword" name="ConfirmPassword" required />
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
          <button type="submit" class="btn btn-primary serif">Cập Nhật Mật Khẩu</button>
        </div>
      </form>
    </div>
  </div>
</div>
