@page
@model MakeForYou.Presentation.Pages.Profile.EditModel
@{
    ViewData["Title"] = "Edit Profile";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">

<div class="serif-scope">
  <div class="serif-container">
    <nav aria-label="Breadcrumb" class="mb-3">
      <ol class="breadcrumb small-caps" style="background:transparent;padding:0;margin:0;display:flex;gap:.5rem;">
        <li class="breadcrumb-item"><a asp-page="/Home/Index" class="text-decoration-none text-reset small-caps">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Profile/Index" class="text-decoration-none text-reset small-caps">Profile</a></li>
        <li class="breadcrumb-item text-muted small-caps" aria-current="page">Edit</li>
      </ol>
    </nav>

    <header class="mb-5">
      <div class="small-caps">Account</div>
      <h1 class="serif-title">Edit Profile</h1>
      <p class="text-muted-serif">Update your account information</p>
    </header>

    @if (Model.UserProfile != null)
    {
      <form method="post" class="row gy-4">
        <div class="col-lg-8">
          <div class="meta-card">
            <div class="small-caps mb-3">Personal Information</div>

            <div class="mb-3">
              <label for="Input_FullName" class="form-label small-caps">Full Name</label>
              <input type="text" class="form-control" id="Input_FullName" name="Input.FullName" value="@Model.Input.FullName" required />
              <span class="text-danger" asp-validation-for="Input.FullName"></span>
            </div>

            <div class="mb-3">
              <label for="Input_Email" class="form-label small-caps">Email Address</label>
              <input type="email" class="form-control" id="Input_Email" name="Input.Email" value="@Model.Input.Email" readonly />
              <small class="text-muted">Email cannot be changed through this form. Contact support if you need to update your email.</small>
            </div>

            <div class="mb-3">
              <label for="Input_Phone" class="form-label small-caps">Phone Number</label>
              <input type="tel" class="form-control" id="Input_Phone" name="Input.Phone" value="@Model.Input.Phone" placeholder="+1 (555) 000-0000" />
              <span class="text-danger" asp-validation-for="Input.Phone"></span>
            </div>

            <div class="d-grid gap-2 mt-4">
              <button type="submit" class="btn btn-primary serif">Save Changes</button>
              <a asp-page="/Profile/Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
          </div>
        </div>

        <aside class="col-lg-4">
          <div class="about-card">
            <div class="small-caps mb-2">Editing Tips</div>
            <p class="serif-body text-muted-serif" style="margin:0;">
              Keep your information up to date so sellers can contact you easily and your orders arrive without delay.
            </p>
          </div>
        </aside>
      </form>
    }
  </div>
</div>
