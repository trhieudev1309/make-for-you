@page "{id:long}"
@model MakeForYou.Presentation.Pages.Products.DetailsModel
@{
    ViewData["Title"] = Model.Product?.Title ?? "Chi tiết tác phẩm";
}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="~/css/serif-theme.css" asp-append-version="true" />

<div class="serif-scope">
    <div class="serif-container">
        @if (Model.Product == null)
        {
            <div class="alert alert-warning" role="alert">Không tìm thấy tác phẩm yêu cầu.</div>
        }
        else
        {
            <nav aria-label="Breadcrumb" class="mb-3">
                <ol class="breadcrumb small-caps" style="background:transparent;padding:0;margin:0;display:flex;gap:.5rem;">
                    <li class="breadcrumb-item"><a asp-page="/Products/Index" class="text-decoration-none text-reset small-caps">Tác phẩm</a></li>
                    <li class="breadcrumb-item text-muted small-caps" aria-current="page">@(Model.Product.Category?.Name ?? "Sản phẩm")</li>
                </ol>
            </nav>

            <header class="mb-5">
                <div class="kicker">Tác phẩm thủ công</div>
                <h1 class="serif-title">@Model.Product.Title</h1>
                @if (!string.IsNullOrEmpty(Model.Product.Description))
                {
                    <p class="small-muted" style="max-width:70ch;">
                        @(Model.Product.Description?.Length > 220 ? Model.Product.Description.Substring(0, 220) + "…" : Model.Product.Description)
                    </p>
                }
            </header>

            <div class="details-grid">
                <div class="left-column">
                    <div class="product-hero-card">
                        <button type="button" class="btn btn-link p-0 text-reset w-100" data-bs-toggle="modal" data-bs-target="#productImageModal" aria-label="Xem ảnh phóng to">
                            @if (!string.IsNullOrEmpty(Model.Product.ImageUrl))
                            {
                                <img src="@Model.Product.ImageUrl" alt="Hình ảnh của @Model.Product.Title" loading="lazy" class="product-image-lg" />
                            }
                            else
                            {
                                <div class="product-image-lg" style="display:flex;align-items:center;justify-content:center;background:#f3f1ee;color:var(--serif-muted);">
                                    <span class="small-caps">Không có hình ảnh</span>
                                </div>
                            }
                        </button>
                    </div>

                    <section>
                        <div class="small-caps mb-3">Mô tả chi tiết tác phẩm</div>
                        <article class="full-desc">
                            <div class="serif-body">@Model.Product.Description</div>
                        </article>
                    </section>
                </div>

                <aside class="right-column">
                    <div class="meta-card">
                        <div class="small-caps">Thông tin ưu đãi</div>
                        <div class="d-flex align-items-baseline justify-content-between">
                            <div>
                                <div class="h3" style="font-family:Playfair Display, Georgia, serif;margin:0;">
                                    @if (Model.Product.Price.HasValue)
                                    {
                                        @Model.Product.Price.Value.ToString("N0") <span style="font-size: 1.1rem; font-weight: 600;">đ</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted-serif" style="font-size: 1.2rem;">Liên hệ để nhận giá</span>
                                    }
                                </div>
                                <div class="small-muted">Đăng ngày @Model.Product.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</div>
                            </div>
                            <div class="small-muted text-end">
                                <div class="small-caps">Tình trạng</div>
                                <div>@((Model.Product.Seller?.AvailabilityStatus == 1) ? "Sẵn sàng giao" : "Liên hệ kiểm tra")</div>
                            </div>
                        </div>

                        <hr style="border-color:var(--serif-border);" />

                        @* KHU VỰC TƯƠNG TÁC GIỎ HÀNG *@
                        <div class="cart-interaction-group mb-4">
                            <div class="small-caps mb-2" style="font-size: 0.6rem; color: var(--mfy-clay, #C8855A);">Tùy chọn mua hàng</div>
                            <div class="d-flex flex-column gap-2">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="qty-selector d-flex align-items-center border rounded-pill px-3 py-1 bg-white">
                                        <button type="button" class="btn btn-sm p-0" onclick="changeQty(-1)"><i class="bi bi-dash"></i></button>
                                        <input type="number" id="purchaseQty" value="1" min="1" class="text-center border-0" style="width: 40px; background:transparent; font-weight: 600;" readonly />
                                        <button type="button" class="btn btn-sm p-0" onclick="changeQty(1)"><i class="bi bi-plus"></i></button>
                                    </div>
                                    <button id="addToCartBtn" class="btn btn-mfy-solid flex-grow-1 rounded-pill fw-bold" 
                                            style="background: var(--mfy-bark, #2D2926); color: white; padding: 10px;" 
                                            onclick="handleAddToCart()">
                                        Thêm vào giỏ hàng
                                    </button>
                                </div>
                                
                                @* NÚT XEM GIỎ HÀNG HIỆN TẠI *@
                                <a href="/Cart/Index" class="btn btn-outline-dark rounded-pill fw-bold d-flex align-items-center justify-content-center gap-2" style="padding: 8px;">
                                    <i class="bi bi-bag-heart"></i> Xem giỏ hàng của tôi
                                </a>
                            </div>
                        </div>

                        @* KHỐI THÔNG TIN PROFILE NGHỆ NHÂN *@
                        <div class="profile-card mt-2">
                            <a href="/Artisans/@Model.Product.SellerId" class="text-decoration-none">
                                <div class="profile-avatar" aria-hidden="true" style="transition: transform 0.2s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                                    @if (!string.IsNullOrEmpty(Model.Product.Seller?.User?.FullName))
                                    {
                                        @Model.Product.Seller.User.FullName.Substring(0,1).ToUpper()
                                    }
                                </div>
                            </a>
                            <div class="profile-meta">
                                <div class="serif-subtitle">
                                    <a href="/Artisans/@Model.Product.SellerId" class="text-decoration-none text-reset fw-bold" style="border-bottom: 1px solid transparent;" onmouseover="this.style.borderColor='var(--serif-gold)'" onmouseout="this.style.borderColor='transparent'">
                                        @Model.Product.Seller?.User?.FullName
                                    </a>
                                </div>
                                <div class="small-muted">@Model.Product.Seller?.SkillDescription</div>

                                <div class="stats-grid">
                                    <div class="stat">
                                        <div class="value">@((Model.Product.Seller?.AverageRating ?? 0).ToString())</div>
                                        <div class="label">Đánh giá</div>
                                    </div>
                                    <div class="stat">
                                        <div class="value">@((Model.Product.Seller?.TotalReviews ?? 0))</div>
                                        <div class="label">Nhận xét</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cta-group mt-3">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @if (!string.IsNullOrEmpty(Model.Product.Seller?.User?.FullName) && Model.Product.SellerId != 0)
                                {
                                    <a class="btn btn-primary serif" 
                                       href="javascript:void(0);" 
                                       onclick="if(window.startChatWithArtisan('@Model.Product.SellerId', '@Html.Raw(Model.Product.Seller.User.FullName.Replace("'", "\\'"))')) { window.location.href='/Chat'; } return false;">
                                         Liên hệ Nghệ nhân
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-primary serif" disabled>Liên hệ tạm khóa</button>
                                }
                            }
                            else
                            {
                                <a class="btn btn-primary serif" href="/Auth/Login?returnUrl=/Products/@Model.Product.ProductId">Đăng nhập để liên hệ</a>
                            }
                            <a asp-page="/Products/Index" class="btn btn-outline-secondary">Quay lại trang tác phẩm</a>
                        </div>

                        <div class="about-card mt-4">
                            <div class="small-caps mb-2">Đôi nét về nghệ nhân</div>
                            <p class="serif-body text-muted-serif" style="margin:0;">
                                @(Model.Product.Seller?.Bio ?? "Chưa có thông tin giới thiệu tiểu sử.")
                            </p>
                        </div>
                    </div>
                </aside>
            </div>

            <section class="reviews-section">
                <div class="reviews-header">
                    <div>
                        <div class="small-caps">Nhận xét từ cộng đồng</div>
                        <h2 class="serif-title" style="font-size:1.25rem;margin:0;">Khách hàng nói gì về chúng tôi</h2>
                    </div>
                    <div class="small-muted">
                        @if ((Model.Product.Seller?.TotalReviews ?? 0) > 0)
                        {
                            <div>@Model.Product.Seller.TotalReviews nhận xét</div>
                        }
                        else
                        {
                            <div>Chưa có nhận xét nào</div>
                        }
                    </div>
                </div>

                <div class="reviews-grid">
                    @if (Model.Product.Seller?.TotalReviews > 0)
                    {
                        <div class="review-card">
                            <div class="review-quote">Kỹ nghệ chế tác tuyệt vời — tác phẩm được bọc gói rất cẩn thận, tinh xảo giống hệt mô tả. Rất khuyến khích trải nghiệm sản phẩm tại đây.</div>
                            <div class="review-meta">
                                <div class="small-muted">— Jane D.</div>
                                <div class="small-muted">03/03/2026</div>
                            </div>
                        </div>
                        <div class="review-card">
                            <div class="review-quote">Đường nét hoàn thiện rất đẹp và giao hàng nhanh chóng. Sẽ tiếp tục ủng hộ nghệ nhân vào lần tới.</div>
                            <div class="review-meta">
                                <div class="small-muted">— Alex S.</div>
                                <div class="small-muted">15/02/2026</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="review-card">
                            <div class="review-quote">Chưa có nhận xét nào từ khách hàng. Hãy là người đầu tiên trải nghiệm và chia sẻ cảm nghĩ của bạn.</div>
                            <div class="review-meta">
                                <div class="small-muted">—</div>
                                <div class="small-muted">—</div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
    </div>
</div>

@Html.AntiForgeryToken()

@* MODAL PHÓNG TO HÌNH ẢNH SẢN PHẨM *@
<div class="modal fade" id="productImageModal" tabindex="-1" aria-labelledby="productImageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="background:transparent;border:none;">
            <div class="modal-body p-0 text-center">
                @if (Model.Product != null && !string.IsNullOrEmpty(Model.Product.ImageUrl))
                {
                    <img src="@Model.Product.ImageUrl" alt="Hình ảnh phóng to của @Model.Product.Title" style="max-width: 100%; border-radius: 12px;" />
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function changeQty(amt) {
            let input = document.getElementById('purchaseQty');
            let val = parseInt(input.value) + amt;
            if (val >= 1) input.value = val;
        }

        async function handleAddToCart() {
            const btn = document.getElementById('addToCartBtn');
            const productId = @Model.Product?.ProductId;
            const quantity = document.getElementById('purchaseQty').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang xử lý...';

            try {
                const response = await fetch(`?handler=AddToCart&productId=${productId}&quantity=${quantity}`, {
                    method: 'POST',
                    headers: { "RequestVerificationToken": token }
                });
                const result = await response.json();
                
                if (result.success) {
                    const badge = document.getElementById('cartBadgeCount');
                    if (badge) badge.innerText = result.newCount;

                    Swal.fire({
                        title: 'Đã thêm vào giỏ hàng!',
                        text: 'Tác phẩm nghệ thuật độc bản của bạn đã được lưu giữ thành công.',
                        icon: 'success',
                        showCancelButton: true,
                        confirmButtonColor: '#2D2926',
                        cancelButtonColor: '#C8855A',
                        confirmButtonText: 'Đến giỏ hàng',
                        cancelButtonText: 'Tiếp tục khám phá'
                    }).then((swalResult) => {
                        if (swalResult.isConfirmed) {
                            window.location.href = '/Cart/Index';
                        }
                    });
                }
            } catch (err) {
                console.error("Cart Error:", err);
            } finally {
                btn.disabled = false;
                btn.innerText = 'Thêm vào giỏ hàng';
            }
        }
    </script>
}