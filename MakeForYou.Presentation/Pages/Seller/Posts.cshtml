@page
@model MakeForYou.Presentation.Pages.Seller.PostsModel
@{
    ViewData["Title"] = "My Posts — MakeForYou";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Source+Sans+3:wght@300;400;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
    :root {
        --bg:       #FAFAF8;
        --card:     #FFFFFF;
        --muted:    #F5F3F0;
        --fg:       #1A1A1A;
        --fg-muted: #6B6B6B;
        --accent:   #B8860B;
        --accent2:  #D4A84B;
        --border:   #E8E4DF;
        --serif:    'Playfair Display', Georgia, serif;
        --sans:     'Source Sans 3', system-ui, sans-serif;
        --mono:     'IBM Plex Mono', monospace;
    }
    body { background: var(--bg); color: var(--fg); font-family: var(--sans); }

    .sp-wrap { max-width: 960px; margin: 0 auto; padding: 3rem 1.5rem 5rem; }

    /* ── page label ── */
    .sp-label { display: flex; align-items: center; gap: 1rem; margin-bottom: 2.5rem; }
    .sp-label-rule { flex: 1; height: 1px; background: var(--border); }
    .sp-label-text {
        font-family: var(--mono); font-size: .72rem; font-weight: 500;
        letter-spacing: .15em; text-transform: uppercase; color: var(--accent);
    }

    /* ── alerts ── */
    .sp-alert {
        display: flex; align-items: center; gap: .75rem;
        padding: .9rem 1.25rem; border-radius: 4px; margin-bottom: 1.5rem;
        font-size: .875rem; animation: fadeSlideIn .3s ease-out;
    }
    .sp-alert-success { background: #f0faf4; border: 1px solid #a8dfc0; color: #1e7a45; }
    .sp-alert-error   { background: #fff5f5; border: 1px solid #f0c0c0; color: #b02020; }
    @@keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(-6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── buttons ── */
    .sp-btn {
        display: inline-flex; align-items: center; gap: .5rem;
        background: var(--accent); color: #fff; border: none; border-radius: 4px;
        padding: 0 1.5rem; height: 40px; font-family: var(--sans);
        font-size: .875rem; font-weight: 600; letter-spacing: .04em;
        cursor: pointer; transition: background .2s, box-shadow .2s, transform .15s;
        text-decoration: none;
    }
    .sp-btn:hover { background: var(--accent2); box-shadow: 0 4px 12px rgba(184,134,11,.2); color: #fff; }
    .sp-btn:active { transform: translateY(1px); }

    .sp-btn-ghost {
        display: inline-flex; align-items: center; gap: .5rem;
        background: transparent; color: var(--fg-muted); border: 1px solid var(--border);
        border-radius: 4px; padding: 0 1.25rem; height: 40px;
        font-family: var(--sans); font-size: .85rem; font-weight: 500;
        cursor: pointer; transition: all .2s; text-decoration: none;
    }
    .sp-btn-ghost:hover { border-color: var(--accent); color: var(--accent); background: transparent; }

    /* ── form shared ── */
    .sp-field { margin-bottom: 1.25rem; }
    .sp-label-field {
        display: block; font-family: var(--mono); font-size: .68rem;
        font-weight: 500; letter-spacing: .12em; text-transform: uppercase;
        color: var(--fg-muted); margin-bottom: .4rem;
    }
    .sp-input {
        width: 100%; padding: .65rem .875rem;
        border: 1px solid var(--border); border-radius: 4px;
        background: transparent; font-family: var(--sans); font-size: .95rem;
        color: var(--fg); outline: none; transition: border-color .15s, box-shadow .15s;
        box-sizing: border-box;
    }
    .sp-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(184,134,11,.12); }
    textarea.sp-input { resize: vertical; line-height: 1.6; min-height: 90px; }
    .sp-input::placeholder { color: var(--fg-muted); opacity: .6; }

    /* ══ COMPOSE / EDIT PANEL ══ */
    .compose-panel {
        background: var(--card);
        border: 1px solid var(--border); border-top: 2px solid var(--accent);
        border-radius: 4px; padding: 1.75rem 2rem;
        margin-bottom: 2.5rem;
        box-shadow: 0 2px 12px rgba(26,26,26,.07);
        /* hidden by default */
        display: none;
    }
    .compose-panel.open {
        display: block;
        animation: panelOpen .22s ease-out;
    }
    @@keyframes panelOpen {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .panel-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 1.5rem;
    }
    .panel-title { font-family: var(--serif); font-size: 1.2rem; margin: 0; }

    .btn-close-panel {
        background: none; border: none; font-size: 1.1rem; cursor: pointer;
        color: var(--fg-muted); padding: .3rem; border-radius: 3px;
        transition: color .15s, background .15s; line-height: 1;
    }
    .btn-close-panel:hover { color: var(--fg); background: var(--muted); }

    /* side-by-side: image picker | fields */
    .compose-body {
        display: grid; grid-template-columns: 160px 1fr;
        gap: 1.5rem; align-items: start;
    }
    @@media (max-width: 560px) { .compose-body { grid-template-columns: 1fr; } }

    /* square image picker */
    .img-drop {
        border: 2px dashed var(--border); border-radius: 4px;
        background: var(--muted); cursor: pointer;
        transition: border-color .2s, background .2s;
        position: relative; overflow: hidden; aspect-ratio: 1/1;
    }
    .img-drop:hover { border-color: var(--accent); background: rgba(184,134,11,.04); }
    .drop-inner {
        position: absolute; inset: 0;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: .4rem; color: var(--fg-muted); pointer-events: none;
    }
    .drop-inner i { font-size: 1.6rem; }
    .drop-inner span { font-size: .72rem; font-family: var(--mono); letter-spacing: .06em; }
    .img-drop input[type=file] {
        position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
    }
    .img-drop .drop-preview {
        position: absolute; inset: 0; width: 100%; height: 100%;
        object-fit: cover; display: none; border-radius: 2px; pointer-events: none;
    }
    .img-drop.has-preview .drop-preview { display: block; }
    .img-drop.has-preview .drop-inner   { display: none; }

    /* current image thumbnail (edit mode) */
    .current-img-wrap { margin-bottom: .6rem; display: none; }
    .current-img-wrap img {
        width: 100%; aspect-ratio: 1/1; object-fit: cover;
        border-radius: 4px; border: 1px solid var(--border); display: block;
    }
    .current-img-label {
        font-family: var(--mono); font-size: .62rem; letter-spacing: .08em;
        text-transform: uppercase; color: var(--fg-muted); margin-top: .35rem;
        text-align: center;
    }

    /* ══ INSTAGRAM GRID ══ */
    .post-grid {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
        margin-bottom: 2.5rem;
    }
    @@media (max-width: 680px) { .post-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 420px) { .post-grid { grid-template-columns: 1fr; } }

    .post-card {
        background: var(--card); border: 1px solid var(--border);
        border-radius: 6px; overflow: hidden;
        transition: box-shadow .2s, transform .2s;
    }
    .post-card:hover {
        box-shadow: 0 6px 20px rgba(26,26,26,.1);
        transform: translateY(-2px);
    }

    /* square image */
    .post-img-wrap {
        position: relative; aspect-ratio: 1/1;
        background: var(--muted); overflow: hidden;
    }
    .post-img-wrap img {
        width: 100%; height: 100%; object-fit: cover; display: block;
        transition: transform .4s ease-out;
    }
    .post-card:hover .post-img-wrap img { transform: scale(1.04); }

    .post-img-placeholder {
        width: 100%; height: 100%;
        display: flex; align-items: center; justify-content: center; color: var(--border);
    }
    .post-img-placeholder i { font-size: 2.5rem; }

    /* hover overlay */
    .post-overlay {
        position: absolute; inset: 0; background: rgba(26,26,26,.48);
        display: flex; align-items: center; justify-content: center; gap: .6rem;
        opacity: 0; transition: opacity .2s;
    }
    .post-card:hover .post-overlay { opacity: 1; }

    .post-action-btn {
        display: inline-flex; align-items: center; gap: .35rem;
        height: 34px; padding: 0 .9rem; border-radius: 3px; border: none;
        font-family: var(--mono); font-size: .68rem; font-weight: 500;
        letter-spacing: .08em; text-transform: uppercase; cursor: pointer;
        transition: background .15s, color .15s;
    }
    .post-action-edit   { background: rgba(255,255,255,.92); color: var(--fg); }
    .post-action-edit:hover { background: #fff; color: var(--accent); }
    .post-action-delete { background: rgba(176,32,32,.82); color: #fff; }
    .post-action-delete:hover { background: #b02020; }

    /* caption */
    .post-caption { padding: .75rem .875rem .875rem; border-top: 1px solid var(--border); }
    .post-caption-title {
        font-family: var(--serif); font-size: .95rem; font-weight: 600;
        color: var(--fg); margin: 0 0 .3rem;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .post-caption-body {
        font-size: .8rem; color: var(--fg-muted); line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .post-caption-date {
        font-family: var(--mono); font-size: .62rem; color: var(--border);
        margin-top: .45rem; letter-spacing: .06em;
    }

    /* empty state */
    .empty-state {
        text-align: center; padding: 4rem 1rem; color: var(--fg-muted);
        grid-column: 1 / -1;
    }
    .empty-state i { font-size: 3rem; display: block; margin-bottom: .75rem; opacity: .3; }
    .empty-state p { font-family: var(--serif); font-size: 1.15rem; color: var(--fg); margin-bottom: .35rem; }
    .empty-state small { font-size: .875rem; }
</style>

<div class="sp-wrap">

    <!-- Page Label -->
    <div class="sp-label">
        <span class="sp-label-rule"></span>
        <span class="sp-label-text">Seller Dashboard</span>
        <span class="sp-label-rule"></span>
    </div>

    <!-- Header -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;">
        <div>
            <h1 style="font-family:var(--serif);font-size:2.1rem;font-weight:400;margin-bottom:.3rem;">My Posts</h1>
            <p style="font-size:.9rem;color:var(--fg-muted);margin:0;">Share your work, process, and story with buyers.</p>
        </div>
        <div style="display:flex;gap:.75rem;align-items:center;flex-wrap:wrap;">
            <a href="/Seller/Profile" class="sp-btn-ghost">
                <i class="bi bi-person-lines-fill"></i> My Profile
            </a>
            <button class="sp-btn" id="btnNewPost" onclick="openCreate()">
                <i class="bi bi-plus-lg"></i> New Post
            </button>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="sp-alert sp-alert-success">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="sp-alert sp-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        </div>
    }

    <!-- ══ COMPOSE / EDIT PANEL ══ -->
    <div class="compose-panel" id="composePanel">
        <div class="panel-header">
            <h2 class="panel-title" id="panelTitle">New Post</h2>
            <button type="button" class="btn-close-panel" onclick="closePanel()" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <form id="composeForm" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <!-- hidden: filled only in edit mode -->
            <input type="hidden" name="PostId" id="panelPostId" value="" />

            <div class="compose-body">
                <!-- Left: image -->
                <div>
                    <label class="sp-label-field">Photo</label>

                    <!-- current image (edit mode only) -->
                    <div class="current-img-wrap" id="currentImgWrap">
                        <img id="currentImg" src="" alt="current photo" />
                        <p class="current-img-label">Current photo</p>
                    </div>

                    <!-- picker -->
                    <div class="img-drop" id="panelDrop">
                        <div class="drop-inner">
                            <i class="bi bi-image"></i>
                            <span id="dropLabel">Upload photo</span>
                        </div>
                        <img class="drop-preview" id="panelPreview" src="" alt="preview" />
                        <input type="file" id="panelFile" name="Image"
                               accept=".jpg,.jpeg,.png,.webp"
                               onchange="onFileChosen(this)" />
                    </div>
                    <p style="font-size:.68rem;color:var(--fg-muted);margin-top:.4rem;font-family:var(--mono);">
                        JPG · PNG · WEBP
                    </p>
                </div>

                <!-- Right: text -->
                <div>
                    <div class="sp-field">
                        <label class="sp-label-field">Caption / Title</label>
                        <input class="sp-input" type="text" name="Title" id="panelTitleInput"
                               maxlength="300" placeholder="A short caption for your post…" required />
                    </div>
                    <div class="sp-field" style="margin-bottom:0;">
                        <label class="sp-label-field">Body</label>
                        <textarea class="sp-input" name="Content" id="panelContent"
                                  rows="6" placeholder="Tell the story behind this piece…" required></textarea>
                    </div>
                </div>
            </div>

            <div style="display:flex;justify-content:flex-end;gap:.75rem;margin-top:1.5rem;padding-top:1.25rem;border-top:1px solid var(--border);">
                <button type="button" class="sp-btn-ghost" onclick="closePanel()">Cancel</button>
                <button type="submit" class="sp-btn" id="panelSubmitBtn">
                    <i class="bi bi-send"></i> Publish
                </button>
            </div>
        </form>
    </div>

    <!-- ══ INSTAGRAM GRID ══ -->
    @if (!Model.Posts.Any())
    {
        <div class="post-grid">
            <div class="empty-state">
                <i class="bi bi-camera"></i>
                <p>No posts yet</p>
                <small>Hit <strong>New Post</strong> to share your first piece.</small>
            </div>
        </div>
    }
    else
    {
        <div class="post-grid">
            @foreach (var post in Model.Posts)
            {
                <div class="post-card" data-post-id="@post.PostId">

                    <!-- Square image -->
                    <div class="post-img-wrap">
                        @if (!string.IsNullOrEmpty(post.ImageUrl))
                        {
                            <img src="@post.ImageUrl" alt="@post.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="post-img-placeholder">
                                <i class="bi bi-file-text"></i>
                            </div>
                        }

                        <!-- Hover overlay -->
                        <div class="post-overlay">
                            <button type="button" class="post-action-btn post-action-edit"
                                    onclick="openEdit(this)">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                            <form method="post" asp-page-handler="Delete" style="display:contents;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="PostId" value="@post.PostId" />
                                <button type="submit" class="post-action-btn post-action-delete"
                                        onclick="return confirm('Delete this post?')">
                                    <i class="bi bi-trash3"></i> Delete
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Caption -->
                    <div class="post-caption">
                        <p class="post-caption-title">@post.Title</p>
                        <p class="post-caption-body">@post.Content</p>
                        <p class="post-caption-date">
                            @post.CreatedAt.ToString("MMM d, yyyy")
                            @if (post.UpdatedAt.HasValue){ <span> · edited</span> }
                        </p>
                    </div>
                </div>
            }
        </div>
    }

    <p style="font-family:var(--mono);font-size:.68rem;color:var(--border);text-align:right;letter-spacing:.08em;">
        @Model.Posts.Count POST@(Model.Posts.Count == 1 ? "" : "S")
    </p>
</div>

@{
    var postsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Posts.Select(p => new {
            id      = p.PostId,
            title   = p.Title,
            content = p.Content,
            image   = p.ImageUrl ?? ""
        })
    ).Replace("</", @"<\/");   // prevent </script> inside a string from closing the tag
}
<script>
const POSTS = @Html.Raw(postsJson);

    const panel     = document.getElementById('composePanel');
    const form      = document.getElementById('composeForm');
    const titleEl   = document.getElementById('panelTitle');
    const postIdEl  = document.getElementById('panelPostId');
    const titleIn   = document.getElementById('panelTitleInput');
    const contentIn = document.getElementById('panelContent');
    const submitBtn = document.getElementById('panelSubmitBtn');
    const dropEl    = document.getElementById('panelDrop');
    const dropLabel = document.getElementById('dropLabel');
    const preview   = document.getElementById('panelPreview');
    const fileIn    = document.getElementById('panelFile');
    const curWrap   = document.getElementById('currentImgWrap');
    const curImg    = document.getElementById('currentImg');

    function resetImagePicker() {
        fileIn.value = '';
        preview.src  = '';
        dropEl.classList.remove('has-preview');
    }

    function onFileChosen(input) {
        const file = input.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = e => {
            preview.src = e.target.result;
            dropEl.classList.add('has-preview');
        };
        reader.readAsDataURL(file);
    }

    function openCreate() {
        // switch to create mode
        titleEl.textContent = 'New Post';
        postIdEl.value      = '';
        titleIn.value       = '';
        contentIn.value     = '';
        submitBtn.innerHTML = '<i class="bi bi-send"></i> Publish';
        dropLabel.textContent = 'Upload photo';
        curWrap.style.display = 'none';
        resetImagePicker();
        form.action = '?handler=Create';

        panel.classList.add('open');
        panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function openEdit(btn) {
        const id   = btn.closest('.post-card').dataset.postId;
        const post = POSTS.find(p => String(p.id) === id);
        if (!post) return;

        // switch to edit mode
        titleEl.textContent = 'Edit Post';
        postIdEl.value      = post.id;
        titleIn.value       = post.title;
        contentIn.value     = post.content;
        submitBtn.innerHTML = '<i class="bi bi-check2"></i> Save Changes';
        dropLabel.textContent = 'Replace photo (optional)';
        form.action = '?handler=Update';

        if (post.image) {
            curImg.src            = post.image;
            curWrap.style.display = 'block';
        } else {
            curWrap.style.display = 'none';
        }
        resetImagePicker();

        panel.classList.add('open');
        panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function closePanel() {
        panel.classList.remove('open');
        resetImagePicker();
    }
</script>
