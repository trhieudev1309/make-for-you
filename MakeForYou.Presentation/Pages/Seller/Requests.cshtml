@page
@model MakeForYou.Presentation.Pages.Seller.RequestsModel
@using MakeForYou.BusinessLogic.Enums
@{
    ViewData["Title"] = "Incoming Requests";
}

<style>
    :root {
        --bg:       #FAFAF8;
        --card:     #FFFFFF;
        --muted:    #F5F3F0;
        --fg:       #1A1A1A;
        --fg-muted: #6B6B6B;
        --accent:   #B8860B;
        --accent2:  #D4A84B;
        --border:   #E8E4DF;
        --serif:    'Playfair Display', Georgia, serif;
        --sans:     'Source Sans 3', system-ui, sans-serif;
        --mono:     'IBM Plex Mono', monospace;
    }

    .rq-wrap { max-width: 900px; margin: 0 auto; padding: 3rem 1.5rem 5rem; }

    .rq-label {
        display: flex; align-items: center; gap: 1rem; margin-bottom: 2.5rem;
    }
    .rq-label-rule { flex: 1; height: 1px; background: var(--border); }
    .rq-label-text {
        font-family: var(--mono); font-size: .72rem; font-weight: 500;
        letter-spacing: .15em; text-transform: uppercase; color: var(--accent);
    }

    /* ── filter tabs ── */
    .rq-filters { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-bottom: 2rem; }
    .rq-filter-btn {
        padding: .6rem 1.25rem; font-family: var(--mono); font-size: .7rem;
        letter-spacing: .1em; text-transform: uppercase; color: var(--fg-muted);
        background: none; border: none; border-bottom: 2px solid transparent;
        margin-bottom: -1px; cursor: pointer; transition: color .2s, border-color .2s;
    }
    .rq-filter-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
    .rq-filter-btn:hover:not(.active) { color: var(--fg); }

    /* ── request card ── */
    .rq-card {
        background: var(--card); border: 1px solid var(--border); border-radius: 4px;
        padding: 1.5rem 1.75rem; margin-bottom: 1rem;
        display: grid; grid-template-columns: 1fr auto;
        gap: 1rem; align-items: center;
        box-shadow: 0 1px 2px rgba(26,26,26,.04);
        transition: box-shadow .2s, border-color .2s;
        text-decoration: none; color: inherit;
    }
    .rq-card:hover {
        box-shadow: 0 4px 12px rgba(26,26,26,.08);
        border-color: var(--accent);
        color: inherit; text-decoration: none;
    }
    .rq-card-accent { border-top: 2px solid var(--accent); }

    .rq-card-id {
        font-family: var(--mono); font-size: .68rem; letter-spacing: .1em;
        color: var(--fg-muted); margin-bottom: .3rem;
    }
    .rq-card-buyer {
        font-family: var(--serif); font-size: 1.1rem; color: var(--fg);
        margin-bottom: .25rem;
    }
    .rq-card-desc {
        font-size: .85rem; color: var(--fg-muted);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        max-width: 520px;
    }
    .rq-card-meta {
        display: flex; align-items: center; gap: 1rem; margin-top: .6rem;
        font-family: var(--mono); font-size: .65rem; letter-spacing: .08em;
        text-transform: uppercase; color: var(--fg-muted);
    }
    .rq-card-price { font-family: var(--serif); font-size: 1rem; font-weight: 600;
        color: var(--accent); white-space: nowrap; }

    /* ── status badges ── */
    .rq-badge {
        display: inline-flex; align-items: center; gap: .35rem;
        padding: .2rem .7rem; border-radius: 2px;
        font-family: var(--mono); font-size: .62rem;
        letter-spacing: .1em; text-transform: uppercase; font-weight: 500;
        white-space: nowrap;
    }
    .rq-badge-dot { width: 5px; height: 5px; border-radius: 50%; }
    .badge-pending   { background: #f5f3f0; color: #888; }
    .badge-pending   .rq-badge-dot { background: #bbb; }
    .badge-quoted    { background: #e8f4fb; color: #1a7fa3; }
    .badge-quoted    .rq-badge-dot { background: #1a7fa3; }
    .badge-confirmed { background: #dce6f9; color: #2255b0; }
    .badge-confirmed .rq-badge-dot { background: #2255b0; }
    .badge-inprogress{ background: #fef3d0; color: #9a6800; }
    .badge-inprogress .rq-badge-dot { background: #9a6800; }
    .badge-completed { background: #f0faf4; color: #1e7a45; }
    .badge-completed .rq-badge-dot { background: #1e7a45; }
    .badge-cancelled { background: #fff5f5; color: #b02020; }
    .badge-cancelled .rq-badge-dot { background: #b02020; }

    /* ── empty state ── */
    .rq-empty {
        text-align: center; padding: 5rem 0; color: var(--fg-muted);
    }
    .rq-empty i { font-size: 2.5rem; opacity: .3; display: block; margin-bottom: 1rem; }
    .rq-empty p { font-family: var(--serif); font-size: 1.1rem; color: var(--fg); margin-bottom: .25rem; }
    .rq-empty span { font-size: .875rem; }

    /* ── summary bar ── */
    .rq-summary {
        display: flex; gap: 2.5rem; padding-bottom: 1.75rem;
        margin-bottom: 2rem; border-bottom: 1px solid var(--border);
    }
    .rq-summary-val { font-family: var(--serif); font-size: 1.6rem; display: block; line-height: 1; color: var(--fg); }
    .rq-summary-lbl { font-family: var(--mono); font-size: .62rem; letter-spacing: .12em;
        text-transform: uppercase; color: var(--fg-muted); margin-top: .2rem; }
</style>

<div class="rq-wrap">

    <div class="rq-label">
        <span class="rq-label-rule"></span>
        <span class="rq-label-text">Seller Dashboard</span>
        <span class="rq-label-rule"></span>
    </div>

    <h1 style="font-family:var(--serif);font-size:2.25rem;font-weight:400;margin-bottom:.375rem;">
        Incoming Requests
    </h1>
    <p style="font-size:.9rem;color:var(--fg-muted);margin-bottom:2.5rem;">
        Manage and respond to custom orders from buyers.
    </p>

    <!-- Summary -->
    <div class="rq-summary">
        <div>
            <span class="rq-summary-val">@Model.Orders.Count</span>
            <span class="rq-summary-lbl">Total</span>
        </div>
        <div>
            <span class="rq-summary-val">@Model.Orders.Count(o => o.Status == (int)OrderStatus.Pending)</span>
            <span class="rq-summary-lbl">Pending</span>
        </div>
        <div>
            <span class="rq-summary-val">@Model.Orders.Count(o => o.Status == (int)OrderStatus.InProgress)</span>
            <span class="rq-summary-lbl">In Progress</span>
        </div>
        <div>
            <span class="rq-summary-val">@Model.Orders.Count(o => o.Status == (int)OrderStatus.Completed)</span>
            <span class="rq-summary-lbl">Completed</span>
        </div>
    </div>

    <!-- Filter tabs -->
    <div class="rq-filters">
        <button class="rq-filter-btn active" onclick="filterRequests('all', this)">All</button>
        <button class="rq-filter-btn" onclick="filterRequests('pending', this)">Pending</button>
        <button class="rq-filter-btn" onclick="filterRequests('quoted', this)">Quoted</button>
        <button class="rq-filter-btn" onclick="filterRequests('inprogress', this)">In Progress</button>
        <button class="rq-filter-btn" onclick="filterRequests('completed', this)">Completed</button>
    </div>

    <!-- Request list -->
    @if (!Model.Orders.Any())
    {
        <div class="rq-empty">
            <i class="bi bi-inbox"></i>
            <p>No requests yet</p>
            <span>When buyers send custom orders, they'll appear here.</span>
        </div>
    }
    else
    {
        <div id="request-list">
            @foreach (var order in Model.Orders)
            {
                var statusKey = ((OrderStatus)order.Status) switch {
                    OrderStatus.Pending    => "pending",
                    OrderStatus.Quoted     => "quoted",
                    OrderStatus.Confirmed  => "confirmed",
                    OrderStatus.InProgress => "inprogress",
                    OrderStatus.Completed  => "completed",
                    OrderStatus.Cancelled  => "cancelled",
                    _                     => "pending"
                };
                var badgeClass = "badge-" + statusKey;
                var acceptedQuote = order.Quotations?.FirstOrDefault(q => q.Status == 1);
                var latestQuote   = order.Quotations?.OrderByDescending(q => q.CreatedAt).FirstOrDefault();
                var displayPrice  = order.AgreedPrice ?? acceptedQuote?.ProposedPrice ?? latestQuote?.ProposedPrice;
                var isCartOrder   = order.OrderItems != null && order.OrderItems.Any();

                <a href="/Seller/RequestDetail/@order.OrderId"
                   class="rq-card @(order.Status == (int)OrderStatus.Pending ? "rq-card-accent" : "")"
                   data-status="@statusKey">
                    <div>
                        <div class="rq-card-id">Order #@order.OrderId</div>
                        <div class="rq-card-buyer">@order.Buyer?.FullName</div>
                        <div class="rq-card-desc">
                            @if (isCartOrder)
                            {
                                @($"{order.OrderItems!.Count} item(s) — {string.Join(", ", order.OrderItems.Take(2).Select(i => i.Product?.Title ?? "Item"))}")
                            }
                            else
                            {
                                @(string.IsNullOrEmpty(order.OrderDescription) ? "Custom request" : order.OrderDescription)
                            }
                        </div>
                        <div class="rq-card-meta">
                            <span><i class="bi bi-clock me-1"></i>@order.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                            @if (order.Quotations != null && order.Quotations.Any())
                            {
                                <span><i class="bi bi-tag me-1"></i>@order.Quotations.Count quote(s)</span>
                            }
                        </div>
                    </div>
                    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:.75rem;">
                        <span class="rq-badge @badgeClass">
                            <span class="rq-badge-dot"></span>
                            @((OrderStatus)order.Status)
                        </span>
                        <div class="rq-card-price">
                            @(displayPrice.HasValue ? displayPrice.Value.ToString("N0") + " VNĐ" : "—")
                        </div>
                    </div>
                </a>
            }
        </div>
    }
</div>

<script>
function filterRequests(status, btn) {
    document.querySelectorAll('.rq-filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.rq-card').forEach(card => {
        card.style.display = (status === 'all' || card.dataset.status === status) ? '' : 'none';
    });
}
</script>
