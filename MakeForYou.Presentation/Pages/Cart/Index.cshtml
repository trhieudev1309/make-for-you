@page
@model MakeForYou.Presentation.Pages.Cart.IndexModel
@{
    // Bỏ null để dùng Layout chung, giúp hiện Header có Badge giỏ hàng
    Layout = "_Layout"; 
    ViewData["Title"] = "Your Basket – MakeForYou";
}

@section Styles {
    <style>
        :root { --mfy-ivory: #F9F7F2; --mfy-bark: #2D2926; --mfy-clay: #C8855A; --serif: 'Playfair Display', serif; }
        .cart-header { border-bottom: 2px solid var(--mfy-bark); padding-bottom: 20px; }
        .product-img { width: 80px; height: 100px; object-fit: cover; border-radius: 4px; }
        .cart-row { border-bottom: 1px solid #E8E2D9; padding: 25px 0; align-items: center; }
        .btn-checkout { background: var(--mfy-bark); color: white; border-radius: 50px; padding: 15px 40px; font-weight: 600; text-decoration: none; transition: 0.3s; display: block; width: 100%; text-align: center; }
        .btn-checkout:hover { background: var(--mfy-clay); color: white; transform: translateY(-2px); }
    </style>
}

<div class="container py-5" style="max-width: 1000px;">
    <header class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <a href="/" class="text-decoration-none text-dark small-caps">← Back to Gallery</a>
            <h1 class="display-4 fw-bold mt-2 serif-heading">Your Basket</h1>
        </div>
        <div class="text-end">
            <span class="small-caps" id="pageCartCount">@Model.CartCount Items</span>
        </div>
    </header>

    @if (!Model.CartItems.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x display-1 opacity-25"></i>
            <p class="mt-4 fs-5">Your basket is feeling a bit light.</p>
            <a href="/Products" class="btn btn-outline-dark rounded-pill px-5 mt-2">Find something soul-stirring</a>
        </div>
    }
    else
    {
        <div class="cart-header d-none d-md-flex row m-0">
            <div class="col-6 small-caps">Creation</div>
            <div class="col-2 text-center small-caps">Price</div>
            <div class="col-2 text-center small-caps">Quantity</div>
            <div class="col-2 text-end small-caps">Subtotal</div>
        </div>

        @foreach (var item in Model.CartItems)
        {
            <div class="row m-0 cart-row align-items-center" id="item-row-@item.ProductId">
                <div class="col-6 d-flex align-items-center gap-4">
                    <img src="@item.ImageUrl" class="product-img shadow-sm" alt="@item.ProductName" />
                    <div>
                        <h5 class="fw-bold mb-1" style="font-family: var(--serif);">@item.ProductName</h5>
                        <button onclick="removeItem(@item.ProductId)" class="btn btn-link p-0 text-muted small text-decoration-none border-bottom">Remove</button>
                    </div>
                </div>

                <div class="col-2 text-center fw-light">@item.Price.ToString("N0")</div>

                <div class="col-2 text-center">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                        <button class="btn btn-sm border rounded-circle" style="width:32px; height:32px;" onclick="updateQty(@item.ProductId, -1)">
                            <i class="bi bi-dash"></i>
                        </button>
                        <span class="fw-bold fs-5 mx-1">@item.Quantity</span>
                        <button class="btn btn-sm border rounded-circle" style="width:32px; height:32px;" onclick="updateQty(@item.ProductId, 1)">
                            <i class="bi bi-plus"></i>
                        </button>
                    </div>
                </div>

                <div class="col-2 text-end fw-bold">@item.TotalPrice.ToString("N0") VNĐ</div>
            </div>
        }

        @Html.AntiForgeryToken()

        <div class="row mt-5">
            <div class="col-md-7">
                <div class="p-4 bg-white rounded-4 border">
                    <h6 class="small-caps mb-3">Note for Artisan</h6>
                    <textarea class="form-control border-0 p-0" style="background: transparent;" rows="3" placeholder="Add a personal touch..."></textarea>
                </div>
            </div>
            <div class="col-md-5 text-end">
                <div class="mb-4">
                    <p class="small-caps text-muted mb-1">Total Amount</p>
                    <h2 class="display-5 fw-bold" style="font-family: var(--serif);">@Model.GrandTotal.ToString("N0") VNĐ</h2>
                </div>
                <a href="/Checkout" class="btn-checkout">Complete Purchase</a>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    // Hàm cập nhật Badge trên Header mà không cần F5
    function updateHeaderBadge(count) {
        const badge = document.getElementById('cartBadgeCount');
        if (badge) {
            badge.innerText = count;
        }
        const pageCount = document.getElementById('pageCartCount');
        if (pageCount) {
            pageCount.innerText = count + " Items";
        }
    }

    async function updateQty(pId, change) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const response = await fetch(`/Cart?handler=UpdateQuantity&productId=${pId}&change=${change}`, {
            method: 'POST',
            headers: { "RequestVerificationToken": token }
        });

        const result = await response.json();
        if (result.success) {
            updateHeaderBadge(result.newCount);
            location.reload(); 
        }
    }

    async function removeItem(pId) {
        if(!confirm("Bạn có chắc muốn bỏ sản phẩm này?")) return;
        
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const response = await fetch(`/Cart?handler=RemoveItem&productId=${pId}`, {
            method: 'POST',
            headers: { "RequestVerificationToken": token }
        });

        const result = await response.json();
        if (result.success) {
            updateHeaderBadge(result.newCount);
            location.reload();
        }
    }
</script>
}