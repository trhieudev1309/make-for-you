@page
@model MakeForYou.Presentation.Pages.Checkout.ReturnModel
@{
    ViewData["Title"] = "Kết quả thanh toán – MakeForYou";
    Layout = "_Layout";
}

<div class="container py-5 text-center" style="margin-top: 100px; margin-bottom: 100px;">
    <div class="mb-4">
        @if (Model.IsSuccess)
        {
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        }
        else
        {
            <i class="bi bi-exclamation-circle-fill text-warning" style="font-size: 5rem;"></i>
        }
    </div>

    <h1 class="display-4 fw-bold mb-3" style="font-family: 'Playfair Display', serif;">
        @(Model.IsSuccess ? "Thanh toán thành công!" : "Thanh toán chưa xác nhận")
    </h1>

    <p class="lead mb-4 text-muted">
        @Model.StatusMessage
        <br />
        @if (Model.IsSuccess)
        {
            @:Đơn hàng của bạn đã được cập nhật. Nhấn bên dưới để xem trạng thái mới nhất.
        }
        else
        {
            @:Nếu bạn đã thanh toán, đơn hàng sẽ được xác nhận trong vài phút. Vui lòng kiểm tra trang đơn hàng.
        }
    </p>

    <p class="text-muted small">Mã giao dịch: <strong>#@Model.OrderCode</strong></p>

    <div class="d-flex justify-content-center gap-3 mt-4">
        <a href="/Products" class="btn btn-outline-dark rounded-pill px-5 py-2 fw-bold">
            Tiếp tục mua sắm
        </a>
        @if (Model.RelatedOrderId.HasValue)
        {
            <a href="/Orders/Detail/@Model.RelatedOrderId" class="btn btn-dark rounded-pill px-5 py-2 fw-bold">
                Xem đơn hàng
            </a>
        }
        else
        {
            <a href="/Orders/Index" class="btn btn-dark rounded-pill px-5 py-2 fw-bold">
                Theo dõi đơn hàng
            </a>
        }
    </div>

    <div class="mt-5 p-4 bg-light rounded-4 mx-auto" style="max-width: 500px; border: 1px dashed #ccc;">
        <p class="small text-muted mb-0">
            Bạn có thắc mắc? Liên hệ với chúng tôi qua <span class="text-clay">support@makeforyou.com</span>
        </p>
    </div>
</div>

<style>
    .text-clay { color: #C8855A; }
    body { background-color: #F9F7F2; }
</style>
