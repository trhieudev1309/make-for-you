@page "/Artisans/{id:long}"
@model MakeForYou.Presentation.Pages.Artisans.DetailsModel
@{
    Layout = "_Layout"; 
}

<link href="https://fonts.googleapis.com/css2?family=La+Belle+Aurore&display=swap" rel="stylesheet">

<style>
    :root {
        --serif-gold: #B8860B;
        --serif-gold-light: #D4A017;
        --serif-ink: #1A1A1A;
        --serif-ivory: #FAFAF8; /* Ivory chuẩn không bị tối */
        --serif-border: #E8E4DF;
        --serif-muted: #6B6B6B;
        --signature-font: 'La Belle Aurore', cursive;
    }

    .artisan-container { 
        background-color: var(--serif-ivory); 
        background-image: radial-gradient(#d1d1d1 0.5px, transparent 0.5px);
        background-size: 20px 20px; /* Chấm nhẹ tinh tế thay vì vân giấy đậm */
        min-height: 100vh;
        padding-bottom: 6rem;
    }

    /* ── HEADER SECTION ── */
    .header-wrapper {
        padding: 5rem 0;
        border-bottom: 1px solid var(--serif-border);
        margin-bottom: 4rem;
        background: #fff; /* Làm Header trắng tinh khôi khớp Navbar */
    }

    .artisan-profile-header { 
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 4rem;
        align-items: center;
        animation: fadeInUp 0.8s ease;
    }

    .artisan-avatar-big { 
        width: 180px; height: 180px; border-radius: 50%; 
        background: var(--serif-gold); 
        display: flex; align-items: center; justify-content: center; 
        font-family: 'Playfair Display', serif; font-size: 4.5rem; color: white;
        box-shadow: 0 10px 40px rgba(184, 134, 11, 0.2);
        border: 8px solid var(--serif-ivory);
    }

    .artisan-info h1 { 
        font-family: 'Playfair Display', serif; 
        font-size: 3.8rem; 
        margin: 0.5rem 0; 
        color: var(--serif-ink);
        letter-spacing: -0.03em;
    }

    .skill-badge { 
        font-family: 'IBM Plex Mono', monospace; 
        text-transform: uppercase; 
        letter-spacing: 0.3em; 
        color: var(--serif-gold); 
        font-size: 0.75rem; 
    }

    .artisan-bio-quote {
        font-family: var(--signature-font);
        font-size: 2rem;
        color: var(--serif-muted);
        margin-top: 1rem;
    }

    /* ── STATS BOX ── */
    .stat-vertical {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        border-left: 1px solid var(--serif-border);
        padding-left: 3rem;
    }
    .stat-item-v .value { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: bold; line-height: 1; }
    .stat-item-v .label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--serif-gold); }

    /* ── STORY SECTION (MỤC MỚI ĐẶC SẮC) ── */
    .story-section {
        background: white;
        padding: 4rem;
        border: 1px solid var(--serif-border);
        margin-bottom: 5rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    /* ── PRODUCT CARD ── */
    .gallery-title-wrap { text-align: center; margin-bottom: 4rem; }
    .gallery-title-wrap h2 { font-family: 'Playfair Display', serif; font-size: 3rem; }

    .card-editorial {
        background: white;
        border: 1px solid var(--serif-border);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        overflow: hidden;
    }
    .card-editorial:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.08); border-color: var(--serif-gold); }
    .card-img-editorial { height: 350px; overflow: hidden; position: relative; }
    .card-img-editorial img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
    .card-editorial:hover img { transform: scale(1.08); }

    .card-overlay-btn {
        position: absolute; bottom: 0; left: 0; right: 0;
        background: rgba(26, 26, 26, 0.9); color: white;
        padding: 1rem; text-align: center; font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
        transform: translateY(100%); transition: 0.3s;
    }
    .card-editorial:hover .card-overlay-btn { transform: translateY(0); }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 992px) {
        .artisan-profile-header, .story-section { grid-template-columns: 1fr; text-align: center; }
        .stat-vertical { flex-direction: row; border-left: none; padding-left: 0; justify-content: center; border-top: 1px solid var(--serif-border); padding-top: 2rem; }
        .artisan-avatar-big { margin: 0 auto; }
    }
</style>

<div class="artisan-container">
    <div class="header-wrapper">
        <div class="container">
            <div class="artisan-profile-header">
                <div class="artisan-avatar-big">@Model.GetMonogram()</div>
                
                <div class="artisan-info">
                    <span class="skill-badge">@Model.Artisan.SkillDescription</span>
                    <h1>@Model.Artisan.User.FullName</h1>
                    <div class="artisan-bio-quote">"@Model.Artisan.Bio"</div>
                </div>

                <div class="stat-vertical">
                    <div class="stat-item-v">
                        <div class="value">@Model.Products.Count</div>
                        <div class="label">Creations</div>
                    </div>
                    <div class="stat-item-v">
                        <div class="value text-warning">★ @(Model.Artisan.AverageRating ?? 5)</div>
                        <div class="label">Avg Rating</div>
                    </div>
                    <div class="stat-item-v">
                        <div class="value">@Model.Artisan.TotalReviews</div>
                        <div class="label">Reviews</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="story-section shadow-sm">
            <div>
                <span class="skill-badge" style="font-size: 0.6rem;">The Philosophy</span>
                <h3 style="font-family: 'Playfair Display', serif; font-size: 2rem; margin: 1rem 0;">Chế tác bằng tâm hồn & Đôi tay</h3>
                <p class="text-muted" style="line-height: 1.8;">
                    Mỗi sản phẩm từ <strong>@Model.Artisan.User.FullName</strong> không chỉ là một món đồ, mà là một câu chuyện về chất liệu tự nhiên và sự kiên nhẫn. 
                    Chúng tôi tin rằng sự hoàn hảo nằm ở những chi tiết không hoàn hảo của thủ công.
                </p>
                <div class="mt-4">
                    <a href="/CustomOrders/Create?sellerId=@Model.Artisan.SellerId" class="btn btn-dark rounded-0 px-4 py-2 small-caps" style="font-size: 0.7rem; letter-spacing: 0.2em;">
                        ✦ Request Custom Work
                    </a>
                </div>
            </div>
            <div style="background: var(--serif-ivory); padding: 2rem; border: 1px dashed var(--serif-gold);">
                <h5 style="font-family: 'Playfair Display', serif;">Giao hàng & Đóng gói</h5>
                <p class="small text-muted">Sản phẩm được đóng gói thân thiện với môi trường, kèm thư tay từ nghệ nhân. Thời gian chế tác trung bình: 3-5 ngày.</p>
                <hr>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="small-caps" style="font-size: 0.6rem;">Status</span>
                    <span class="badge rounded-pill bg-success" style="font-size: 0.6rem; letter-spacing: 0.1em;">READY TO SHIP</span>
                </div>
            </div>
        </div>

        <div class="gallery-title-wrap">
            <span class="skill-badge">Curated Collection</span>
            <h2>Works & Gallery</h2>
        </div>

        <div class="row g-4">
            @if (Model.Products.Any())
            {
                @foreach (var p in Model.Products)
                {
                    <div class="col-md-4 col-lg-3">
                        @* Đã sửa lại Link chính xác dẫn về trang Details *@
                        <a href="/Products/Details/@p.ProductId" class="text-decoration-none">
                            <div class="card-editorial">
                                <div class="card-img-editorial">
                                    <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "/images/placeholder.jpg" : p.ImageUrl)" alt="@p.Title">
                                    <div class="card-overlay-btn">Discover Piece</div>
                                </div>
                                <div class="p-4">
                                    <span class="skill-badge" style="font-size: 0.55rem; letter-spacing: 0.1em;">@p.Category?.Name</span>
                                    <h5 class="item-title" style="font-family: 'Playfair Display', serif; color: var(--serif-ink); margin: 0.5rem 0;">@p.Title</h5>
                                    <div class="pt-3 border-top mt-3 fw-bold" style="color: var(--serif-gold); font-family: 'Playfair Display', serif;">
                                        @Model.FormatPrice(p.Price)
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted italic">Nghệ nhân chưa đăng tải sản phẩm nào.</p>
                </div>
            }
        </div>
    </div>
</div>